---
import BaseHead from '@/components/BaseHead.astro';
import Navbar from '@/components/organisms/Navbar.astro';
import SiteFooter from '@/components/organisms/SiteFooter.astro';
import Icon from '@/components/atoms/Icon.astro';

const title = 'Servicio Cross-Border (Transfronterizo) | Traustar Logistics Inc.';
const description = 'Despacho aduanal fluido y confiabilidad de puerta a puerta para su carga internacional. Conectamos EE.UU., México y Canadá.';

const valueProps = [
	{ icon: 'gavel', title: 'Expertos en Aduanas', description: 'Gestión experta de trámites y cumplimiento normativo para evitar retrasos costosos en las fronteras.' },
	{ icon: 'visibility', title: 'Visibilidad en Tiempo Real', description: 'Seguimiento preciso de sus embarques en cada etapa del trayecto transfronterizo con tecnología de punta.' },
	{ icon: 'verified_user', title: 'Red de Carriers Verificados', description: 'Colaboramos exclusivamente con transportistas certificados y altamente confiables en los tres países.' },
];

const capabilities = [
	{ icon: 'swap_horiz', title: 'Drayage Transfronterizo', description: 'Transferencias eficientes y rápidas en puntos fronterizos clave.' },
	{ icon: 'warehouse', title: 'Almacén y Cross-dock en Laredo', description: 'Instalaciones estratégicas para optimizar y consolidar su carga.' },
	{ icon: 'satellite_alt', title: 'Monitoreo 24/7 con GPS', description: 'Control satelital ininterrumpido para seguridad total de su mercancía.' },
];

const faqs = [
	{ q: '¿Qué documentos necesito para un envío transfronterizo?', a: 'Principalmente se requiere Factura Comercial, Lista de Empaque (Packing List), Bill of Lading (B/L) y el Pedimento para México o Entry Form para EE.UU. Nuestro equipo le asesorará paso a paso.' },
	{ q: '¿Cómo gestionan las demoras en las fronteras?', a: 'Utilizamos pre-despachos aduanales y una red de carriers con estatus FAST/Express para agilizar los cruces. Además, nuestra visibilidad en tiempo real nos permite reaccionar ante cualquier contingencia.' },
	{ q: '¿Cuentan con servicios de cross-dock en la frontera?', a: 'Sí, disponemos de instalaciones estratégicas en Laredo, TX, diseñadas específicamente para realizar transferencias de carga eficientes de carriers mexicanos a estadounidenses y viceversa.' },
];

const certBadges = [
	{ label: 'C-TPAT', sub: 'Certified Partner' },
	{ label: 'FMCSA', sub: 'Registered Authority' },
	{ label: 'DOT', sub: 'Safety Compliant' },
];

const coverageCities = [
	{ name: 'CANADÁ', cities: 'Toronto • Vancouver • Montreal' },
	{ name: 'USA', cities: 'Chicago • Laredo • Dallas • NY' },
	{ name: 'MÉXICO', cities: 'CDMX • Monterrey • Querétaro' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-white text-slate-900 font-display">
		<Navbar />

		<!-- Hero -->
		<section class="relative h-[600px] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 bg-cover bg-center" style="background-image: linear-gradient(rgba(16,22,34,0.7),rgba(16,22,34,0.8)), url('/images/svc-cb-hero.jpg');"></div>
			<div class="relative z-10 container mx-auto px-4 sm:px-6 text-center">
				<div class="max-w-4xl mx-auto flex flex-col items-center gap-6">
					<span class="bg-primary/20 text-primary border border-primary/30 px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest">Norteamérica Conectada</span>
					<h1 class="text-white text-4xl md:text-6xl font-black leading-tight tracking-tight">
						Logística Transfronteriza Sin Fronteras: Conectando EE.UU., México y Canadá
					</h1>
					<p class="text-slate-300 text-lg md:text-xl max-w-2xl font-normal leading-relaxed">
						Despacho aduanal fluido y confiabilidad de puerta a puerta para su carga internacional.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 mt-4">
						<a href="/quote/cross-border" class="flex min-w-[200px] items-center justify-center rounded-lg h-14 px-8 bg-primary text-white text-base font-bold transition-transform hover:scale-105">
							Solicitar Cotización Transfronteriza
						</a>
						<a href="#cobertura" class="flex min-w-[200px] items-center justify-center rounded-lg h-14 px-8 bg-white/10 text-white text-base font-bold border border-white/20 hover:bg-white/20">
							Ver Nuestras Rutas
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Value Props -->
		<section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-4xl font-bold mb-4">Propuesta de Valor</h2>
					<div class="w-20 h-1.5 bg-primary mx-auto rounded-full"></div>
					<p class="text-slate-600 mt-6 max-w-2xl mx-auto">Soluciones diseñadas para maximizar la eficiencia y seguridad en el transporte por Norteamérica.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{valueProps.map((vp) => (
						<div class="flex flex-col items-center text-center p-8 rounded-xl border border-slate-200 bg-slate-50 hover:shadow-xl transition-shadow">
							<div class="size-16 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-6">
								<Icon name={vp.icon} size="text-4xl" />
							</div>
							<h3 class="text-xl font-bold mb-4">{vp.title}</h3>
							<p class="text-slate-600 leading-relaxed">{vp.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Capabilities -->
		<section class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-50">
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
				<div class="lg:w-1/2 space-y-8">
					<div>
						<h2 class="text-3xl md:text-4xl font-bold mb-6">Capacidades Operativas de Alto Nivel</h2>
						<p class="text-slate-600 text-lg">Nuestra infraestructura está diseñada para responder a los retos más complejos del comercio exterior.</p>
					</div>
					<div class="space-y-6">
						{capabilities.map((cap) => (
							<div class="flex gap-4 p-4 rounded-lg bg-white border border-slate-200">
								<Icon name={cap.icon} className="text-primary" size="text-3xl" />
								<div>
									<h4 class="font-bold">{cap.title}</h4>
									<p class="text-sm text-slate-600">{cap.description}</p>
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="lg:w-1/2 relative">
					<div class="aspect-square rounded-2xl overflow-hidden shadow-2xl">
						<img alt="Centro de control logístico" class="object-cover w-full h-full" src="/images/svc-cb-ops.jpg" loading="lazy" />
					</div>
					<div class="absolute -bottom-6 -left-6 bg-primary p-6 rounded-xl shadow-xl text-white">
						<div class="text-4xl font-black">15+</div>
						<div class="text-sm uppercase tracking-wider opacity-80">Años de experiencia</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Coverage -->
		<section class="py-20 px-4 sm:px-6 lg:px-8 bg-white" id="cobertura">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col items-center text-center mb-12">
					<h2 class="text-3xl font-bold mb-4">Cobertura Estratégica en Norteamérica</h2>
					<p class="text-slate-600 max-w-2xl">Conectamos los principales hubs industriales de México con los centros de consumo masivo en EE.UU. y Canadá.</p>
				</div>
				<div class="bg-slate-100 rounded-2xl p-8 min-h-[400px] flex items-center justify-center border border-slate-200 relative overflow-hidden">
					<div class="relative flex flex-wrap justify-center gap-12 font-bold text-lg md:text-2xl text-slate-400">
						{coverageCities.map((region) => (
							<div class="flex flex-col items-center">
								<span class="text-primary">{region.name}</span>
								<span class="text-xs font-normal">{region.cities}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Trust -->
		<section class="py-16 px-4 sm:px-6 lg:px-8 bg-primary/5">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-12">
				<div class="md:w-1/3">
					<h2 class="text-3xl font-bold mb-4">Compromiso con la Seguridad</h2>
					<p class="text-slate-600">Cumplimos con los más altos estándares y certificaciones internacionales para garantizar la integridad de su carga.</p>
				</div>
				<div class="md:w-2/3 grid grid-cols-3 gap-8">
					{certBadges.map((cert) => (
						<div class="flex flex-col items-center gap-2">
							<div class="w-24 h-24 bg-white rounded-lg shadow-sm flex items-center justify-center p-4 border border-slate-100">
								<span class="font-black text-2xl text-slate-400">{cert.label}</span>
							</div>
							<span class="text-xs font-bold text-center text-slate-500">{cert.sub}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
			<div class="max-w-3xl mx-auto">
				<div class="text-center mb-12">
					<h2 class="text-3xl font-bold mb-4">Preguntas Frecuentes</h2>
					<p class="text-slate-600">Resolvemos sus dudas sobre logística internacional.</p>
				</div>
				<div class="space-y-4">
					{faqs.map((faq, i) => (
						<details class="group border border-slate-200 rounded-lg overflow-hidden" open={i === 0}>
							<summary class="flex justify-between items-center p-5 cursor-pointer bg-slate-50 font-bold list-none">
								{faq.q}
								<Icon name="expand_more" className="transition-transform group-open:rotate-180" />
							</summary>
							<div class="p-5 text-slate-600 border-t border-slate-200">{faq.a}</div>
						</details>
					))}
				</div>
			</div>
		</section>

		<SiteFooter />
	</body>
</html>

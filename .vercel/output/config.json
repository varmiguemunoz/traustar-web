{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/carriers/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/faq/?$",
			"dest": "_render"
		},
		{
			"src": "^/glossary/?$",
			"dest": "_render"
		},
		{
			"src": "^/logistics-guides/logistics-guides/?$",
			"dest": "_render"
		},
		{
			"src": "^/market-rate-reports/market-rate-reports/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/quote/cross-border/?$",
			"dest": "_render"
		},
		{
			"src": "^/quote/ftl/?$",
			"dest": "_render"
		},
		{
			"src": "^/quote/ltl/?$",
			"dest": "_render"
		},
		{
			"src": "^/quote/?$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/servicios/carga-especializada/?$",
			"dest": "_render"

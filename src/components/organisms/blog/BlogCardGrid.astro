---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '@/components/FormattedDate.astro';
import fallbackImage from '@/assets/blog-placeholder-1.jpg';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const [featuredPost, ...otherPosts] = posts;
---

<section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
  <header class="mb-12 border-b border-slate-200 pb-8">
    <h1 class="mb-4 text-4xl font-black tracking-tight text-slate-900 sm:text-5xl">Insights and Logistics Intelligence</h1>
    <p class="max-w-3xl text-lg text-slate-600">
      Explore practical articles on freight strategy, market trends, and transportation operations.
    </p>
  </header>

  {featuredPost && (
    <article class="group mb-12 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-xl">
      <a href={`/blog/${featuredPost.id}/`} class="grid grid-cols-1 md:grid-cols-2">
        <div class="overflow-hidden">
          <Image
            src={featuredPost.data.heroImage ?? fallbackImage}
            alt={featuredPost.data.title}
            width={1200}
            height={720}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
        <div class="flex flex-col justify-center p-8">
          <p class="mb-3 text-xs font-bold uppercase tracking-wider text-primary">Featured article</p>
          <h2 class="mb-4 text-3xl font-black tracking-tight text-slate-900 transition-colors group-hover:text-primary">
            {featuredPost.data.title}
          </h2>
          <p class="mb-6 text-slate-600">{featuredPost.data.description}</p>
          <p class="text-sm font-medium text-slate-500">
            <FormattedDate date={featuredPost.data.pubDate} />
          </p>
        </div>
      </a>
    </article>
  )}

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
    {otherPosts.map((post) => (
      <article class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-xl">
        <a href={`/blog/${post.id}/`}>
          <Image
            src={post.data.heroImage ?? fallbackImage}
            alt={post.data.title}
            width={720}
            height={420}
            class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="p-6">
            <h2 class="mb-3 text-xl font-bold text-slate-900 transition-colors group-hover:text-primary">{post.data.title}</h2>
            <p class="mb-5 text-sm leading-relaxed text-slate-600">{post.data.description}</p>
            <p class="text-sm font-medium text-slate-500">
              <FormattedDate date={post.data.pubDate} />
            </p>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

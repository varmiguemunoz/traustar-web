---
---

<section class="py-24 relative overflow-hidden bg-primary">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/cta-highway.jpg"
      alt=""
      role="presentation"
      class="w-full h-full object-cover opacity-20"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-screen-2xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-black text-white tracking-tighter uppercase mb-6 sm:text-4xl md:text-5xl md:mb-8 lg:text-7xl">
      Ready to move your freight?
    </h2>
    <p class="text-base text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed sm:text-lg md:text-xl md:mb-12">
      Experience the precision of Traustar. Let's optimize your logistics today.
    </p>
    <a
      href="/quote"
      class="inline-flex items-center justify-center bg-white text-primary px-8 py-4 rounded-xl font-black text-base shadow-2xl hover:scale-105 transition-transform uppercase tracking-tighter cursor-pointer min-h-[44px] sm:px-10 sm:py-5 sm:text-lg md:px-12 md:py-6 md:text-xl"
    >
      Request a Quote
    </a>
  </div>
</section>

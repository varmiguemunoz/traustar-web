---
import Icon from '../atoms/Icon.astro';
import SectionLabel from '../atoms/SectionLabel.astro';

const techFeatures = [
  {
    icon: 'analytics',
    title: 'Data-Driven Pricing',
    description: 'Algorithms process market signals to secure strong cost-performance outcomes.'
  },
  {
    icon: 'my_location',
    title: '24/7 Tracking',
    description: 'Shipment location, milestones, and ETA updates are available in real time.'
  },
  {
    icon: 'integration_instructions',
    title: 'EDI and API Integrations',
    description: 'Connect Traustar workflows with your TMS and ERP systems.'
  },
  {
    icon: 'dashboard_customize',
    title: 'Client Portal',
    description: 'Centralized access to documents, invoices, and shipment history.'
  }
];
---

<section id="technology" class="bg-white py-24">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-16 px-4 sm:px-6 lg:flex-row lg:px-8">
    <div class="lg:w-1/2">
      <SectionLabel>Freight Technology</SectionLabel>
      <h2 class="mb-8 text-3xl font-black text-navy-deep sm:text-4xl">Complete supply chain visibility in one platform</h2>
      <ul class="space-y-6">
        {techFeatures.map((feature) => (
          <li class="flex items-start gap-4">
            <Icon name={feature.icon} className="mt-1 text-primary" />
            <div>
              <h4 class="text-lg font-bold">{feature.title}</h4>
              <p class="text-slate-500">{feature.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="w-full lg:w-1/2">
      <div class="rounded-2xl border border-slate-700 bg-navy-deep p-4 shadow-2xl">
        <div class="mb-4 flex items-center gap-2 px-2">
          <div class="h-3 w-3 rounded-full bg-red-500"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
          <div class="h-3 w-3 rounded-full bg-green-500"></div>
        </div>
        <div class="overflow-hidden rounded-lg bg-slate-900">
          <img
            src="/images/dashboard-mockup.jpg"
            alt="Traustar dashboard with analytics and shipment tracking"
            class="h-auto w-full opacity-90"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

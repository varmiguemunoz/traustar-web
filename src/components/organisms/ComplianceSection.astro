---
const details = [
  {
    title: 'Safety Standards',
    description: 'Rigorous vetting of CSA scores and safety ratings for every dispatch.'
  },
  {
    title: 'FMCSA Monitoring',
    description: 'Automated alerts for authority changes or insurance expirations.'
  },
  {
    title: 'Document Control',
    description: 'Digital storage and immediate retrieval of BOLs, PODs, and receipts.'
  },
  {
    title: 'Cargo Insurance',
    description: 'Contingent cargo and general liability policies for maximum protection.'
  }
];
---

<section class="py-24 bg-surface-dim" aria-label="Compliance and carrier network">
  <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl overflow-hidden shadow-2xl flex flex-col lg:rounded-3xl md:flex-row">
      <!-- Left: Primary Card -->
      <div class="bg-primary p-8 text-white sm:p-10 md:w-1/3 md:p-12">
        <span class="material-symbols-outlined text-5xl mb-4 sm:text-6xl sm:mb-6" aria-hidden="true">verified_user</span>
        <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 sm:text-3xl">Elite Compliance</h3>
        <p class="text-white/80 leading-relaxed mb-6 text-sm sm:text-base sm:mb-8">
          We hold our carrier network to the highest safety standards in the industry. FMCSA monitoring is automated and real-time.
        </p>
        <a
          href="/carriers"
          class="block w-full border-2 border-white text-white py-3 font-black uppercase tracking-tighter rounded-lg hover:bg-white hover:text-primary transition-colors text-center cursor-pointer min-h-[44px] flex items-center justify-center"
        >
          Carrier Portal
        </a>
      </div>

      <!-- Right: Details Grid -->
      <div class="p-8 grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 md:w-2/3 md:p-12">
        {details.map((detail) => (
          <div class="space-y-2">
            <h4 class="font-black uppercase tracking-tight text-primary text-sm sm:text-base">{detail.title}</h4>
            <p class="text-slate-500 text-sm">{detail.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import Icon from '@/components/atoms/Icon.astro';

interface HighlightItem {
  icon: string;
  label: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  highlights: HighlightItem[];
}

const { badge, title, description, image, imageAlt, highlights } = Astro.props;
---

<section class="pt-28">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-4 pb-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:px-8">
    <div>
      <p class="mb-6 inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-primary">
        <Icon name="verified_user" size="text-sm" />
        {badge}
      </p>
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-6xl">{title}</h1>
      <p class="max-w-xl text-lg leading-relaxed text-slate-600">{description}</p>

      <ul class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {highlights.map((highlight) => (
          <li class="flex items-center gap-2 text-sm font-semibold text-slate-700">
            <Icon name={highlight.icon} className="text-primary" />
            {highlight.label}
          </li>
        ))}
      </ul>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-2xl">
      <img
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover"
        loading="eager"
        width="1200"
        height="900"
      />
    </div>
  </div>
</section>

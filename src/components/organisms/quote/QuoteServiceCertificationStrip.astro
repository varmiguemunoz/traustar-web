---
import Icon from '@/components/atoms/Icon.astro';

interface CertificationItem {
  icon: string;
  label: string;
}

interface Props {
  items: CertificationItem[];
}

const { items } = Astro.props;
---

<section class="border-t border-slate-200 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ul class="flex flex-wrap items-center justify-center gap-8">
      {items.map((item) => (
        <li class="flex items-center gap-2 text-slate-500">
          <Icon name={item.icon} size="text-3xl" />
          <span class="text-lg font-black tracking-wide">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
}

const { title, description, image, imageAlt } = Astro.props;
---

<section class="relative overflow-hidden bg-slate-900 py-16 lg:py-24">
  <div class="absolute inset-0 opacity-35">
    <div class="absolute inset-0 z-10 bg-gradient-to-r from-primary/50 to-transparent"></div>
    <img
      src={image}
      alt={imageAlt}
      class="h-full w-full object-cover"
      loading="eager"
      width="1600"
      height="900"
    />
  </div>
  <div class="relative z-20 mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
    <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight text-white md:text-6xl">{title}</h1>
    <p class="mx-auto max-w-2xl text-lg leading-relaxed text-slate-200 md:text-xl">{description}</p>
  </div>
</section>

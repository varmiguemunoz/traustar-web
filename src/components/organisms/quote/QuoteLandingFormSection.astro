---
import Icon from '@/components/atoms/Icon.astro';
import Button from '@/components/atoms/Button.astro';
import type { QuoteLandingData } from '@/data/quote';

interface Props {
  data: QuoteLandingData;
}

const { data } = Astro.props;
---

<section class="relative z-10 -mt-12 pb-24">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-xl md:p-10 lg:col-span-8">
      <form class="space-y-10" action="#" method="post">
        <section>
          <div class="mb-6 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">1</span>
            <h2 class="text-xl font-bold text-slate-900">Shipment Type</h2>
          </div>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
            {data.shipmentTypes.map((type) => (
              <a
                href={type.href}
                class="group flex min-h-24 flex-col items-center justify-center rounded-xl border-2 border-slate-100 p-4 text-center transition-colors hover:border-primary/50"
              >
                <Icon name={type.icon} size="text-3xl" className="mb-2 text-slate-400 group-hover:text-primary" />
                <span class="text-xs font-bold uppercase tracking-wide">{type.label}</span>
              </a>
            ))}
          </div>
        </section>

        <section>
          <div class="mb-6 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">2</span>
            <h2 class="text-xl font-bold text-slate-900">Origin and Destination</h2>
          </div>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <label class="space-y-2">
              <span class="text-sm font-semibold text-slate-600">Origin (ZIP, City, State)</span>
              <span class="relative block">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icon name="location_on" /></span>
                <input
                  type="text"
                  placeholder="e.g. 60608 Chicago, IL"
                  class="w-full rounded-lg border border-slate-200 py-3 pl-10 pr-4 transition-colors focus:border-primary focus:ring-primary"
                />
              </span>
            </label>
            <label class="space-y-2">
              <span class="text-sm font-semibold text-slate-600">Destination (ZIP, City, State)</span>
              <span class="relative block">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icon name="flag" /></span>
                <input
                  type="text"
                  placeholder="e.g. 78045 Laredo, TX"
                  class="w-full rounded-lg border border-slate-200 py-3 pl-10 pr-4 transition-colors focus:border-primary focus:ring-primary"
                />
              </span>
            </label>
          </div>
        </section>

        <section>
          <div class="mb-6 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">3</span>
            <h2 class="text-xl font-bold text-slate-900">Cargo Details</h2>
          </div>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            <label class="space-y-2">
              <span class="text-sm font-semibold text-slate-600">Commodity Type</span>
              <input
                type="text"
                placeholder="e.g. Consumer electronics"
                class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary"
              />
            </label>
            <label class="space-y-2">
              <span class="text-sm font-semibold text-slate-600">Total Weight (lbs)</span>
              <input
                type="text"
                placeholder="e.g. 33000"
                class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary"
              />
            </label>
            <label class="space-y-2">
              <span class="text-sm font-semibold text-slate-600">Pallet Count</span>
              <input
                type="number"
                placeholder="e.g. 24"
                class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary"
              />
            </label>
          </div>
          <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
            <h3 class="md:col-span-2 text-sm font-bold uppercase tracking-wide text-slate-800">Special Requirements</h3>
            {data.specialRequirements.map((requirement) => (
              <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-slate-100 p-3 transition-colors hover:bg-slate-50">
                <input type="checkbox" class="rounded text-primary focus:ring-primary" />
                <span class="text-sm text-slate-700">{requirement}</span>
              </label>
            ))}
          </div>
        </section>

        <section class="rounded-xl border border-primary/20 bg-primary/5 p-6 md:p-8">
          <div class="mb-6 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">4</span>
            <h2 class="text-xl font-bold text-slate-900">Contact Information</h2>
          </div>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <input type="text" placeholder="Full Name" class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary" />
            <input type="text" placeholder="Company Name" class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary" />
            <input type="email" placeholder="Business Email" class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary" />
            <input type="tel" placeholder="Phone Number" class="w-full rounded-lg border border-slate-200 px-4 py-3 transition-colors focus:border-primary focus:ring-primary" />
          </div>
        </section>

        <div class="pt-2">
          <Button variant="primary" size="lg" className="flex w-full items-center justify-center gap-2 text-lg">
            Get My Quote Now <Icon name="arrow_forward" />
          </Button>
          <p class="mt-4 text-center text-xs text-slate-500">
            By submitting this form, you agree to our
            <a href="/terms" class="text-primary underline">Terms of Service</a>
            and
            <a href="/privacy" class="text-primary underline">Privacy Policy</a>.
          </p>
        </div>
      </form>
    </div>

    <aside class="space-y-6 lg:col-span-4">
      <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-md">
        <h2 class="mb-6 text-lg font-bold text-primary">Why choose Traustar?</h2>
        <div class="space-y-6">
          {data.valueProps.map((prop) => (
            <article class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <Icon name={prop.icon} />
              </div>
              <div>
                <h3 class="text-sm font-bold text-slate-900">{prop.title}</h3>
                <p class="mt-1 text-xs leading-relaxed text-slate-500">{prop.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="rounded-xl bg-slate-900 p-6 text-white shadow-md">
        <h2 class="mb-4 text-center text-xs font-bold uppercase tracking-wider text-slate-400">{data.trust.heading}</h2>
        <div class="grid grid-cols-2 gap-4 opacity-80">
          {data.trust.certifications.map((certification) => (
            <div class="flex flex-col items-center gap-1 text-center">
              <Icon name="verified" size="text-3xl" />
              <span class="text-xs font-bold uppercase tracking-wide">{certification}</span>
            </div>
          ))}
        </div>
        <hr class="my-6 border-slate-700" />
        <p class="text-center text-xs italic leading-relaxed text-slate-300">&quot;{data.trust.testimonial}&quot;</p>
      </section>

      <section class="relative h-48 overflow-hidden rounded-xl border border-slate-200 shadow-md">
        <img
          src={data.map.image}
          alt={data.map.alt}
          class="h-full w-full object-cover"
          loading="lazy"
          width="960"
          height="480"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-primary/25">
          <p class="rounded-lg bg-white/90 px-3 py-2 text-center text-xs font-bold uppercase tracking-wide text-slate-900 shadow-lg">
            {data.map.badge}
          </p>
        </div>
      </section>
    </aside>
  </div>
</section>

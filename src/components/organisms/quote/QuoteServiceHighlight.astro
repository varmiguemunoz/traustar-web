---
import Icon from '@/components/atoms/Icon.astro';

interface Props {
  title: string;
  description: string;
  bullets: string[];
  image: string;
  imageAlt: string;
  theme: 'primary' | 'slate';
}

const { title, description, bullets, image, imageAlt, theme } = Astro.props;

const sectionClass =
  theme === 'primary' ? 'bg-primary text-white' : 'bg-slate-900 text-white';
const paragraphClass = theme === 'primary' ? 'text-blue-100' : 'text-slate-300';
---

<section class="px-4 py-24 sm:px-6 lg:px-8">
  <div class:list={['mx-auto grid max-w-7xl items-center gap-12 rounded-3xl p-8 md:p-14 lg:grid-cols-2', sectionClass]}>
    <div>
      <h2 class="mb-6 text-3xl font-black tracking-tight md:text-4xl">{title}</h2>
      <p class:list={['mb-8 text-lg leading-relaxed', paragraphClass]}>{description}</p>
      <ul class="space-y-4">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 rounded-full bg-white px-1.5 py-1 text-primary">
              <Icon name="check" size="text-sm" />
            </span>
            <span class="font-medium">{bullet}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="overflow-hidden rounded-2xl shadow-2xl">
      <img
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover"
        loading="lazy"
        width="1200"
        height="800"
      />
    </div>
  </div>
</section>

---
import Icon from '@/components/atoms/Icon.astro';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  title?: string;
  items: FaqItem[];
}

const { title = 'Frequently asked questions', items } = Astro.props;
---

{items.length > 0 && (
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-12 text-center text-3xl font-bold">{title}</h2>
      <div class="space-y-4">
        {items.map((faq, index) => (
          <details class="group rounded-lg border border-slate-200 bg-slate-50 p-6" open={index === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
              <h3 class="text-lg font-bold">{faq.q}</h3>
              <Icon name="expand_more" className="transition-transform group-open:-rotate-180" />
            </summary>
            <p class="mt-4 leading-relaxed text-slate-600">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

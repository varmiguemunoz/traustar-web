---
/**
 * FeatureWithImage — Split layout with image + feature items list.
 * Used for capabilities, security, or operations sections.
 */
import Icon from '@/components/atoms/Icon.astro';

interface FeatureItem {
	icon: string;
	title: string;
	description: string;
}

interface Props {
	sectionTitle: string;
	sectionDescription?: string;
	features: FeatureItem[];
	image: string;
	imageAlt?: string;
	/** 'light' or 'dark' background */
	variant?: 'light' | 'dark';
	/** Image on left or right */
	imagePosition?: 'left' | 'right';
}

const {
	sectionTitle,
	sectionDescription,
	features,
	image,
	imageAlt = 'Service feature',
	variant = 'light',
	imagePosition = 'left',
} = Astro.props;

const isDark = variant === 'dark';
const sectionBg = isDark ? 'bg-slate-900 text-white' : 'bg-white';
const textMuted = isDark ? 'text-slate-400' : 'text-slate-600';
const iconColor = isDark ? 'text-primary text-3xl' : 'text-primary';
---

<section class={`py-16 md:py-24 ${sectionBg} overflow-hidden`}>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class={`grid lg:grid-cols-2 gap-12 lg:gap-16 items-center ${imagePosition === 'right' ? '' : ''}`}>
			{/* Image Side */}
			<div class={`${imagePosition === 'right' ? 'order-1 lg:order-2' : ''}`}>
				<div class={`rounded-2xl overflow-hidden shadow-2xl ${isDark ? 'border border-slate-700' : ''}`}>
					<div
						class="aspect-square bg-cover bg-center bg-slate-200"
						style={`background-image: url('${image}');`}
						role="img"
						aria-label={imageAlt}
					></div>
				</div>
			</div>

			{/* Content Side */}
			<div class={`space-y-8 md:space-y-12 ${imagePosition === 'right' ? 'order-2 lg:order-1' : ''}`}>
				<div>
					<h2 class="text-3xl md:text-4xl font-black mb-4 md:mb-6 tracking-tight">{sectionTitle}</h2>
					{sectionDescription && (
						<p class={`text-lg leading-relaxed ${textMuted}`}>{sectionDescription}</p>
					)}
				</div>
				<div class="grid sm:grid-cols-2 gap-6 md:gap-8">
					{features.map((feat) => (
						<div class="flex gap-4">
							<div class="shrink-0">
								<Icon name={feat.icon} className={iconColor} size="text-3xl" />
							</div>
							<div>
								<h5 class="font-bold text-lg mb-1">{feat.title}</h5>
								<p class={`text-sm ${textMuted}`}>{feat.description}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

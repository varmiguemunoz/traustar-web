---
import Icon from '@/components/atoms/Icon.astro';

interface Props {
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const { title, description, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="bg-primary py-20 text-white">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
    <h2 class="mb-6 text-3xl font-bold tracking-tight">{title}</h2>
    <p class="mb-10 text-lg opacity-90">{description}</p>
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={primaryHref}
        class="inline-flex min-h-11 items-center gap-2 rounded-lg bg-white px-8 py-4 font-bold text-primary transition-transform hover:scale-105"
      >
        <Icon name="mail" />
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex min-h-11 items-center gap-2 rounded-lg border-2 border-white/30 bg-transparent px-8 py-4 font-bold transition-colors hover:bg-white/10"
      >
        <Icon name="call" />
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>

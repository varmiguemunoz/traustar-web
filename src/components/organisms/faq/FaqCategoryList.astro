---
import Icon from '@/components/atoms/Icon.astro';
import type { FaqCategory } from '@/data/faq';

interface Props {
  categories: FaqCategory[];
}

const { categories } = Astro.props;
---

<section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
  <div class="grid gap-16">
    {categories.map((category) => (
      <section>
        <div class="mb-8 flex items-center gap-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
            <Icon name={category.icon} />
          </span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-900">{category.title}</h2>
        </div>

        <div class="space-y-4">
          {category.items.map((item) => (
            <details class="group rounded-xl border border-slate-200 bg-white p-1 transition-colors open:ring-1 open:ring-primary">
              <summary class="flex cursor-pointer list-none items-center justify-between p-5 font-semibold text-slate-900 transition-colors group-hover:text-primary">
                {item.question}
                <Icon name="expand_more" className="transition-transform duration-300 group-open:rotate-180" />
              </summary>
              <p class="px-5 pb-5 pt-0 leading-relaxed text-slate-600">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    ))}
  </div>
</section>

---
import Icon from '@/components/atoms/Icon.astro';

interface Props {
  title: string;
  description: string;
  searchPlaceholder: string;
}

const { title, description, searchPlaceholder } = Astro.props;
---

<section class="relative overflow-hidden bg-slate-900 pb-24 pt-32 text-white">
  <div class="absolute inset-0 z-0 opacity-40 bg-cover bg-center" style="background-image: linear-gradient(rgba(15, 73, 189, 0.4), rgba(16, 22, 34, 0.9)), url('/images/nosotros-hero.jpg');"></div>
  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6">
    <h1 class="mb-6 text-4xl font-black tracking-tight sm:text-6xl">{title}</h1>
    <p class="mx-auto mb-10 max-w-2xl text-lg text-slate-300 sm:text-xl">{description}</p>
    <div class="mx-auto max-w-2xl">
      <label class="group relative flex items-center" for="faq-search">
        <span class="absolute left-4 text-slate-400"><Icon name="search" /></span>
        <input
          id="faq-search"
          type="text"
          placeholder={searchPlaceholder}
          class="h-16 w-full rounded-xl border-none bg-white px-12 text-slate-900 shadow-2xl ring-4 ring-primary/10 transition-colors focus:ring-primary/30"
        />
      </label>
    </div>
  </div>
</section>

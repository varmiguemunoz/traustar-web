---
import Button from '../atoms/Button.astro';
---

<section class="py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl bg-navy-deep p-12 text-center lg:p-20">
      <div class="absolute -right-32 -top-32 h-64 w-64 rounded-full bg-primary/20 blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 h-64 w-64 rounded-full bg-primary/10 blur-3xl"></div>

      <h2 class="relative z-10 mb-8 text-3xl font-black text-white sm:text-4xl lg:text-5xl">
        Ready to optimize your freight operations?
      </h2>
      <p class="relative z-10 mx-auto mb-12 max-w-2xl text-lg text-slate-400 sm:text-xl">
        Request a tailored quote and work with a logistics team built for high-performance execution.
      </p>
      <div class="relative z-10">
        <Button variant="primary" size="lg" href="/quote" className="px-12 py-5 text-xl shadow-2xl shadow-primary/40">
          Request a Quote
        </Button>
      </div>
    </div>
  </div>
</section>

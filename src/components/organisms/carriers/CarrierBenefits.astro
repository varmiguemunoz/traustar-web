---
import Icon from '@/components/atoms/Icon.astro';

interface Item {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section class="border-t border-slate-100 bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">Why carriers choose Traustar</h2>
    <p class="mt-4 text-slate-600">Our operating model is designed to improve fleet profitability and execution clarity.</p>
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <article class="group rounded-2xl border border-slate-200 p-8 text-left transition-all hover:border-primary/50">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all group-hover:bg-primary group-hover:text-white">
            <Icon name={item.icon} size="text-3xl" />
          </div>
          <h3 class="mb-3 text-xl font-bold">{item.title}</h3>
          <p class="text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="border-y border-slate-200 bg-white py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-center gap-12 opacity-60 transition-all hover:opacity-100">
      {items.map((item) => (
        <div class="flex items-center gap-2 text-2xl font-black">{item}</div>
      ))}
    </div>
  </div>
</section>

---
import Icon from '@/components/atoms/Icon.astro';

interface Item {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section class="bg-white py-24" id="carrier-requirements">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-primary px-8 py-16 text-white lg:px-16">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-black sm:text-4xl">Onboarding requirements</h2>
          <p class="mt-4 text-blue-100/80">
            Fast qualification workflow so your fleet can begin hauling quickly with complete compliance clarity.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {items.map((item) => (
            <div class="flex gap-4">
              <Icon name={item.icon} />
              <div>
                <p class="font-bold">{item.title}</p>
                <p class="text-sm text-blue-100/70">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

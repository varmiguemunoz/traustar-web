---
import Icon from '@/components/atoms/Icon.astro';
---

<section class="overflow-hidden bg-slate-50 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-16 lg:flex-row">
      <div class="space-y-6 lg:w-1/2">
        <h2 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">
          Technology built for driver and dispatcher efficiency
        </h2>
        <p class="text-lg text-slate-600">
          Minimize paperwork and reduce call volume with simple digital workflows for updates, POD uploads, and load communications.
        </p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3"><Icon name="check_circle" className="text-primary" /> Instant POD upload workflows</li>
          <li class="flex items-center gap-3"><Icon name="check_circle" className="text-primary" /> Real-time GPS shipment visibility</li>
          <li class="flex items-center gap-3"><Icon name="check_circle" className="text-primary" /> Automated load notifications</li>
        </ul>
      </div>

      <div class="relative flex justify-center lg:w-1/2">
        <div class="relative z-10 w-64 rounded-[3rem] border-8 border-slate-900 bg-slate-900 p-2 shadow-2xl">
          <div class="h-[500px] w-full overflow-hidden rounded-[2.5rem] bg-white">
            <div class="space-y-4 p-6 text-center">
              <div class="flex justify-center text-primary"><Icon name="local_shipping" size="text-4xl" /></div>
              <h3 class="font-bold">Active Load</h3>
              <div class="rounded-lg bg-slate-100 p-4 text-left">
                <p class="text-xs text-slate-500">ORIGIN</p>
                <p class="text-sm font-bold">Laredo, TX</p>
                <div class="my-2 ml-2 h-8 w-px bg-slate-300"></div>
                <p class="text-xs text-slate-500">DESTINATION</p>
                <p class="text-sm font-bold">Monterrey, NL</p>
              </div>
              <button class="w-full rounded-lg bg-primary py-2 text-sm font-bold text-white">View Details</button>
            </div>
          </div>
        </div>
        <div class="absolute -right-8 top-1/2 -z-0 h-96 w-96 -translate-y-1/2 rounded-full bg-primary/10 blur-3xl"></div>
      </div>
    </div>
  </div>
</section>

---
import StatItem from '../molecules/StatItem.astro';

const metrics = [
  { value: '50k+', label: 'Loads Delivered' },
  { value: '1,400+', label: 'Carrier Network' },
  { value: '99.8%', label: 'On-Time Rate' },
  { value: '15+', label: 'Years in Operation' }
];
---

<section class="bg-navy-deep py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
      {metrics.map((metric) => <StatItem value={metric.value} label={metric.label} />)}
    </div>
  </div>
</section>

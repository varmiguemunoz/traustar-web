---
import TestimonialStars from '../molecules/TestimonialStars.astro';

const testimonials = [
  {
    quote: '“Traustar helped us scale our Texas operation with consistent visibility and dependable transit performance.”',
    name: 'Ricardo Mendez',
    role: 'Logistics Manager, InduMex',
    industry: 'Manufacturing'
  },
  {
    quote: '“Their reefer execution has been flawless. We have had zero cold-chain incidents since onboarding.”',
    name: 'Sarah Williams',
    role: 'Operations VP, FreshFoods Inc.',
    industry: 'Food & Beverage'
  },
  {
    quote: '“When cross-border timelines are at risk, Traustar responds immediately and protects our delivery windows.”',
    name: 'Javier Ortiz',
    role: 'Managing Director, AutoPartes Global',
    industry: 'Automotive'
  }
];
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="mb-16 text-center text-3xl font-black text-navy-deep sm:text-4xl">What our clients say</h2>
    <div class="grid gap-8 md:grid-cols-3">
      {testimonials.map((testimonial) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <TestimonialStars count={5} />
          <p class="mb-8 mt-4 italic text-slate-600">{testimonial.quote}</p>
          <div>
            <p class="font-bold">{testimonial.name}</p>
            <p class="text-sm text-slate-500">{testimonial.role}</p>
            <p class="mt-1 text-xs font-bold uppercase text-primary">{testimonial.industry}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

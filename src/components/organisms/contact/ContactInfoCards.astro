---
import Icon from '@/components/atoms/Icon.astro';

interface ContactCard {
  icon: string;
  title: string;
  subtitle: string;
  value: string;
  href: string;
}

interface Props {
  cards: readonly ContactCard[];
}

const { cards } = Astro.props;
---

<section class="relative z-10 mx-auto -mt-16 max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    {cards.map((card) => (
      <article class="group rounded-xl border border-slate-100 bg-white p-8 shadow-xl transition-colors hover:border-primary/50">
        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary transition-transform group-hover:scale-110">
          <Icon name={card.icon} />
        </div>
        <h2 class="mb-2 text-lg font-bold text-slate-900">{card.title}</h2>
        <p class="mb-4 text-sm text-slate-500">{card.subtitle}</p>
        {card.href ? (
          <a href={card.href} class="font-semibold text-primary hover:underline">{card.value}</a>
        ) : (
          <p class="font-semibold text-slate-900">{card.value}</p>
        )}
      </article>
    ))}
  </div>
</section>

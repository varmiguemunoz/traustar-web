---
import { Leaflet, Marker, Popup, OpenPopup } from 'astro-leaflet';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// 2327 N Harding Ave, Chicago, IL 60647
const OFFICE_LAT = 41.9243;
const OFFICE_LNG = -87.7248;
const OFFICE_ADDRESS = '2327 N Harding Ave, Chicago, IL 60647';
---

<section class="w-full bg-slate-100 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-slate-900">{title}</h2>
      <p class="mx-auto max-w-2xl text-slate-500">{description}</p>
    </header>

    <div class="relative h-96 overflow-hidden rounded-2xl border-4 border-white shadow-2xl md:h-[500px]">
      <Leaflet
        options={{
          center: [OFFICE_LAT, OFFICE_LNG],
          zoom: 15,
          mapOptions: {
            scrollWheelZoom: false,
          },
        }}
      >
        <Marker latlng={[OFFICE_LAT, OFFICE_LNG]}>
          <Popup content={`<strong>Traustar Logistics</strong><br/>${OFFICE_ADDRESS}`} />
          <OpenPopup />
        </Marker>
      </Leaflet>
    </div>
  </div>
</section>

<style>
  /* Ensure Leaflet map fills the container */
  .relative :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    z-index: 0;
  }
</style>

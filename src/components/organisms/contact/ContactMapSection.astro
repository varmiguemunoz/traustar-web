---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
}

const { title, description, image, imageAlt } = Astro.props;
---

<section class="w-full bg-slate-100 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-slate-900">{title}</h2>
      <p class="mx-auto max-w-2xl text-slate-500">{description}</p>
    </header>

    <div class="relative h-96 overflow-hidden rounded-2xl border-4 border-white shadow-2xl md:h-[500px]">
      <img src={image} alt={imageAlt} class="h-full w-full object-cover" loading="lazy" width="1600" height="900" />
      <div class="pointer-events-none absolute inset-0 bg-primary/10"></div>
    </div>
  </div>
</section>

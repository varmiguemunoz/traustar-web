---
import Icon from '../atoms/Icon.astro';
import Button from '../atoms/Button.astro';
---

<section class="relative overflow-hidden pb-20 pt-32 lg:pb-28 lg:pt-44">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 z-10 bg-gradient-to-r from-white via-white/85 to-transparent"></div>
    <div class="h-full w-full bg-cover bg-center" style="background-image: url('/images/hero-bg.jpg');"></div>
  </div>

  <div class="relative z-20 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="mb-6 text-4xl font-black leading-[1.1] tracking-tighter text-navy-deep sm:text-5xl lg:text-7xl">
        Guaranteed <span class="text-primary">Capacity</span> for Critical Freight
      </h1>
      <p class="mb-8 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Remove uncertainty from your supply chain with 24/7 shipment visibility,
        optimized market rates, and a vetted carrier network across North America.
      </p>

      <div class="mb-12 flex flex-wrap gap-4">
        <Button variant="primary" size="lg" href="/quote" className="shadow-xl shadow-primary/30">
          Get a Quote <Icon name="arrow_forward" />
        </Button>
        <Button variant="secondary" size="lg" href="/services">
          Explore Services
        </Button>
      </div>

      <div class="flex flex-wrap items-center gap-6 border-t border-slate-200 py-6 sm:gap-8">
        <div class="flex items-center gap-2 text-sm font-bold text-navy-deep sm:text-base">
          <Icon name="verified" className="text-primary" /> FMCSA Compliant
        </div>
        <div class="flex items-center gap-2 text-sm font-bold text-navy-deep sm:text-base">
          <Icon name="schedule" className="text-primary" /> 99.8% On-time
        </div>
        <div class="flex items-center gap-2 text-sm font-bold text-navy-deep sm:text-base">
          <Icon name="groups" className="text-primary" /> 1,400+ Carriers
        </div>
      </div>
    </div>
  </div>
</section>

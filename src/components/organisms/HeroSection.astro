---
import Button from '../atoms/Button.astro';
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-on-background">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-terminal.jpg"
      alt=""
      role="presentation"
      class="w-full h-full object-cover opacity-40"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-on-background via-on-background/80 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-screen-2xl w-full px-4 py-20 sm:px-6 lg:px-8">
    <div class="max-w-4xl">
      <h1 class="text-4xl font-black text-white tracking-tighter leading-[0.9] mb-8 uppercase sm:text-5xl md:text-6xl lg:text-8xl">
        Control, Visibility, and Capacity: <span class="text-primary">Your Supply Chain, Mastered</span>
      </h1>
      <p class="text-lg text-slate-300 mb-12 max-w-2xl leading-relaxed sm:text-xl md:text-2xl">
        Traustar Logistics manages freight across the US, Mexico, and Canada with competitive pricing and real-time monitoring.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
        <Button
          variant="primary"
          size="lg"
          href="/quote"
          className="px-10 py-5 text-lg font-black shadow-2xl shadow-primary/40 hover:scale-105 transition-transform uppercase tracking-tighter"
        >
          Get a Quote
        </Button>
        <a
          href="/contact"
          class="inline-flex items-center justify-center border-2 border-white/30 text-white px-10 py-5 rounded-xl font-black text-lg backdrop-blur-sm hover:bg-white/10 transition-colors uppercase tracking-tighter cursor-pointer"
        >
          Talk to a Specialist
        </a>
      </div>
    </div>
  </div>

  <!-- Subtle Glow Radiance -->
  <div class="absolute bottom-0 right-0 w-64 h-64 bg-primary/20 blur-[120px] rounded-full translate-x-1/2 translate-y-1/2 sm:w-80 sm:h-80 lg:w-[500px] lg:h-[500px]"></div>
</section>

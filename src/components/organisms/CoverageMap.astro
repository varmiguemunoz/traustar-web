---
const regions = ['Mexico', 'United States', 'Canada'];
---

<section id="coverage" class="bg-background-light py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-black text-navy-deep sm:text-4xl">Coverage across North America</h2>
      <p class="text-slate-500">Reliable lanes and strategic carrier capacity across key trade corridors.</p>
    </div>

    <div class="relative mx-auto aspect-video w-full max-w-5xl overflow-hidden rounded-3xl shadow-2xl">
      <img
        src="/images/coverage-map.jpg"
        alt="Coverage map for Traustar routes across North America"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="flex flex-wrap justify-center gap-4">
          {regions.map((region) => (
            <span class="rounded-full bg-white/90 px-6 py-2 text-sm font-bold shadow-lg sm:text-base">{region}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
import FeatureItem from '../molecules/FeatureItem.astro';

const features = [
  {
    icon: 'payments',
    title: 'Real-Time Pricing',
    description: 'Market-informed rates for faster decisions and better cost control.'
  },
  {
    icon: 'satellite_alt',
    title: 'Live Tracking',
    description: '24/7 GPS visibility for every active shipment in your network.'
  },
  {
    icon: 'bolt',
    title: 'Fast Execution',
    description: 'Rapid response to urgent tenders and critical recovery scenarios.'
  },
  {
    icon: 'gavel',
    title: 'Regulatory Compliance',
    description: 'Carrier vetting and compliance governance aligned with federal standards.'
  }
];
---

<section id="why-us" class="bg-background-light py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div>
        <h2 class="mb-8 text-3xl font-black text-navy-deep sm:text-4xl">
          Why Traustar is a strategic logistics partner
        </h2>
        <div class="grid gap-8 sm:grid-cols-2">
          {features.map((feature) => (
            <FeatureItem icon={feature.icon} title={feature.title} description={feature.description} />
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-full bg-primary/20 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-3xl shadow-2xl">
          <img
            src="/images/team-control.jpg"
            alt="Traustar operations team in a logistics control center"
            class="h-auto w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

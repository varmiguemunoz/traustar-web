---
import Icon from '../atoms/Icon.astro';
import ServiceLink from '../molecules/ServiceLink.astro';

const services = [
  {
    icon: 'local_shipping',
    title: 'FTL (Full Truckload)',
    description: 'Dedicated trailer capacity for high-volume shipments and direct routes.',
    href: '/services/ftl'
  },
  {
    icon: 'inventory_2',
    title: 'LTL (Less-Than-Truckload)',
    description: 'Cost-efficient shipping where you only pay for the space you use.',
    href: '/services/ltl'
  },
  {
    icon: 'public',
    title: 'Cross-Border',
    description: 'Customs-ready freight execution across the US, Mexico, and Canada.',
    href: '/services/cross-border'
  },
  {
    icon: 'ac_unit',
    title: 'Reefer',
    description: 'Temperature-controlled transport for perishables and pharmaceuticals.',
    href: '/services/reefer'
  },
  {
    icon: 'conveyor_belt',
    title: 'Flatbed & Heavy Haul',
    description: 'Specialized open-deck solutions for oversized and industrial cargo.',
    href: '/services/flatbed'
  },
  {
    icon: 'train',
    title: 'Intermodal',
    description: 'Rail and road combinations that improve long-haul economics and sustainability.',
    href: '/services/intermodal'
  }
];
---

<section id="services" class="bg-white py-24">
  <div class="mx-auto mb-16 max-w-7xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="mb-4 text-3xl font-black text-navy-deep sm:text-4xl">Integrated Logistics Solutions</h2>
    <p class="mx-auto max-w-2xl text-slate-500">
      Diverse equipment and specialized freight services designed around your operational requirements.
    </p>
  </div>

  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 md:grid-cols-2 lg:grid-cols-3 lg:px-8">
    {services.map((service) => (
      <div class="group rounded-2xl border border-transparent bg-background-light p-8 transition-all hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/5">
        <Icon name={service.icon} size="text-4xl" className="mb-6 text-primary" />
        <h3 class="mb-3 text-xl font-bold">{service.title}</h3>
        <p class="mb-6 text-slate-600">{service.description}</p>
        <ServiceLink href={service.href} />
      </div>
    ))}
  </div>
</section>

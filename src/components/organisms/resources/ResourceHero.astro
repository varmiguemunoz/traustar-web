---
import Icon from '@/components/atoms/Icon.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbLabel: string;
}

const { title, description, breadcrumbLabel } = Astro.props;
---

<section class="border-b border-slate-200 bg-white pb-16 pt-28 sm:pb-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <nav class="mb-4 flex items-center gap-2 text-sm font-medium text-primary" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <Icon name="chevron_right" size="text-xs" />
        <span class="text-slate-500">{breadcrumbLabel}</span>
      </nav>
      <h1 class="mb-6 text-4xl font-black tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">{title}</h1>
      <p class="text-lg leading-relaxed text-slate-600 sm:text-xl">{description}</p>
    </div>
  </div>
</section>

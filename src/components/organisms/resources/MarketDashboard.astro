---
import Icon from '@/components/atoms/Icon.astro';

interface SpotRateCard {
  icon: string;
  label: string;
  trend: string;
  price: string;
  change: string;
  positive: boolean;
  accentClass: string;
}

interface RegionItem {
  name: string;
  status: string;
  percentage: number;
  statusClass: string;
  barClass: string;
}

interface Props {
  spotRates: SpotRateCard[];
  regions: RegionItem[];
  summary: string[];
  cta: {
    title: string;
    description: string;
    label: string;
    href: string;
  };
}

const { spotRates, regions, summary, cta } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
    <section class="flex flex-col gap-4 lg:col-span-2">
      <article class="overflow-hidden rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
          <h2 class="flex items-center gap-2 text-xl font-bold text-slate-900">
            <Icon name="map" className="text-primary" />
            Lane Rate Heatmap - North America
          </h2>
          <div class="rounded-lg bg-slate-100 p-1 text-xs font-bold">
            <span class="rounded bg-white px-3 py-1 shadow-sm">Map view</span>
            <span class="px-3 py-1 text-slate-500">List view</span>
          </div>
        </header>

        <div class="relative aspect-[16/9] overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
          <img src="/images/market-heatmap.jpg" alt="Freight lane heatmap across North America" class="h-full w-full object-cover opacity-80" loading="lazy" width="1280" height="720" />
          <div class="absolute inset-0 bg-primary/5"></div>

          <div class="absolute left-4 top-4 right-4 flex items-start justify-between gap-3">
            <label class="relative w-full max-w-64" for="lane-search">
              <span class="absolute left-3 top-2.5 text-slate-400"><Icon name="search" size="text-lg" /></span>
              <input id="lane-search" type="text" placeholder="Search lane" class="w-full rounded-lg border-none bg-white py-2 pl-10 pr-3 text-sm shadow-lg focus:ring-2 focus:ring-primary" />
            </label>
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-lg">
              <button class="block border-b border-slate-100 p-2 transition-colors hover:bg-slate-50" type="button">
                <Icon name="add" />
              </button>
              <button class="block p-2 transition-colors hover:bg-slate-50" type="button">
                <Icon name="remove" />
              </button>
            </div>
          </div>

          <div class="absolute bottom-4 left-4 rounded-lg border border-slate-200 bg-white/90 p-3 shadow-lg backdrop-blur-sm">
            <p class="mb-2 text-xs font-bold uppercase text-slate-500">Price intensity ($/mi)</p>
            <div class="flex items-center gap-2 text-xs">
              <span>$1.20</span>
              <span class="h-2 w-32 rounded-full bg-gradient-to-r from-blue-500 via-green-400 via-yellow-400 to-red-500"></span>
              <span>$4.50+</span>
            </div>
          </div>
        </div>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="mb-4 text-lg font-bold text-slate-900">Weekly Market Summary</h3>
        <div class="space-y-3 text-sm leading-relaxed text-slate-600">
          {summary.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </article>
    </section>

    <aside class="flex flex-col gap-8">
      <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="mb-6 text-sm font-black uppercase tracking-widest text-slate-500">National Avg Spot Rates</h3>
        <div class="space-y-6">
          {spotRates.map((rate) => (
            <article class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <span class:list={['flex h-10 w-10 items-center justify-center rounded-lg', rate.accentClass]}>
                  <Icon name={rate.icon} />
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-900">{rate.label}</p>
                  <p class="text-xs text-slate-500">Trend: {rate.trend}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-lg font-bold text-slate-900">{rate.price}</p>
                <p class:list={['text-xs font-bold', rate.positive ? 'text-emerald-500' : 'text-red-500']}>
                  {rate.change}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="mb-4 text-sm font-black uppercase tracking-widest text-slate-500">Regional Capacity</h3>
        <div class="space-y-4">
          {regions.map((region) => (
            <article>
              <div class="mb-1 flex justify-between text-xs font-bold">
                <span>{region.name}</span>
                <span class={region.statusClass}>{region.status}</span>
              </div>
              <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
                <div class:list={['h-full rounded-full', region.barClass]} style={`width: ${region.percentage}%`}></div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="relative overflow-hidden rounded-xl bg-primary p-6 shadow-lg">
        <div class="relative z-10">
          <h3 class="mb-2 text-xl font-bold text-white">{cta.title}</h3>
          <p class="mb-6 text-sm text-white/80">{cta.description}</p>
          <a href={cta.href} class="inline-flex min-h-11 w-full items-center justify-center rounded-lg bg-white px-4 py-3 text-center font-bold text-primary transition-colors hover:bg-slate-100">
            {cta.label}
          </a>
        </div>
        <div class="absolute -bottom-6 -right-6 h-32 w-32 rounded-full bg-white/10 blur-2xl"></div>
      </section>
    </aside>
  </div>
</section>

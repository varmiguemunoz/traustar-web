---
import Icon from '@/components/atoms/Icon.astro';
import type { ResourceGuide } from '@/data/resources';

interface Props {
  guides: ResourceGuide[];
}

const { guides } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <header class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-center">
    <h2 class="text-2xl font-bold text-slate-900">Featured Educational Guides</h2>
    <a href="/contact" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
      Request a custom guide
      <Icon name="arrow_forward" size="text-sm" />
    </a>
  </header>

  <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {guides.map((guide) => (
      <article class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white transition-transform hover:-translate-y-1 hover:shadow-xl">
        <div class="relative aspect-[16/10] overflow-hidden bg-slate-200">
          <img src={guide.image} alt={guide.imageAlt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" width="960" height="600" />
          <span class="absolute right-3 top-3 rounded-full bg-white/90 p-2 text-primary shadow-sm">
            <Icon name={guide.icon} />
          </span>
        </div>
        <div class="flex flex-1 flex-col p-6">
          <h3 class="mb-3 text-lg font-bold leading-snug text-slate-900 transition-colors group-hover:text-primary">{guide.title}</h3>
          <p class="mb-6 flex-1 text-sm leading-relaxed text-slate-600">{guide.description}</p>
          <button class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-slate-100 px-4 py-2.5 text-sm font-bold text-slate-900 transition-colors hover:bg-primary hover:text-white" type="button">
            <Icon name="download" size="text-lg" />
            Download guide
          </button>
        </div>
      </article>
    ))}
  </div>
</section>

---
import Button from '@/components/atoms/Button.astro';
---

<section class="relative flex items-center justify-center overflow-hidden py-28 md:py-36">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: linear-gradient(rgba(15, 73, 189, 0.7), rgba(16, 22, 34, 0.9)), url('/images/nosotros-hero.jpg');"
  ></div>
  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6">
    <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight text-white md:text-6xl">
      Human-Centered Logistics, Powered by Technology
    </h1>
    <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-200 md:text-xl">
      We combine enterprise-grade freight technology with dedicated account support to keep your supply chain moving without friction.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button variant="primary" size="lg" href="/services" className="shadow-lg">Explore Services</Button>
      <Button
        variant="secondary"
        size="lg"
        href="/quote"
        className="border-white/30 bg-white/10 text-white hover:bg-white/20"
      >
        Request a Quote
      </Button>
    </div>
  </div>
</section>

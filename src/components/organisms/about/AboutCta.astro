---
import Icon from '@/components/atoms/Icon.astro';
---

<section class="px-4 py-16 sm:px-6">
  <div class="mx-auto max-w-4xl overflow-hidden rounded-2xl bg-primary p-10 text-center text-white shadow-2xl md:p-16">
    <h2 class="mb-6 text-3xl font-bold md:text-4xl">Ready to strengthen your supply chain execution?</h2>
    <p class="mb-10 text-lg text-blue-100 opacity-90">
      Work with a logistics team built for speed, control, and reliable cross-border outcomes.
    </p>
    <div class="flex flex-wrap justify-center gap-6">
      <a href="/shippers" class="flex items-center gap-2 rounded-xl bg-white px-10 py-4 font-bold text-primary transition-all hover:bg-slate-100">
        <Icon name="business" /> I Am a Shipper
      </a>
      <a href="/carriers" class="flex items-center gap-2 rounded-xl border border-white/50 bg-white/10 px-10 py-4 font-bold text-white transition-all hover:bg-white/20">
        <Icon name="local_shipping" /> I Am a Carrier
      </a>
    </div>
  </div>
</section>

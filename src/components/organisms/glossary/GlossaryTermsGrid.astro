---
import Icon from '@/components/atoms/Icon.astro';
import type { GlossaryTerm } from '@/data/glossary';

interface Props {
  terms: GlossaryTerm[];
}

const { terms } = Astro.props;
---

<section class="mx-auto w-full max-w-7xl px-4 pb-10 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {terms.map((term) => (
      <article class="group rounded-2xl border border-slate-200 bg-white p-6 transition-colors hover:border-primary/50">
        <div class="mb-3 flex items-start justify-between gap-4">
          <h2 class="text-2xl font-bold text-slate-900 transition-colors group-hover:text-primary">{term.name}</h2>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase text-slate-500">{term.category}</span>
        </div>
        <p class="mb-4 leading-relaxed text-slate-600">{term.description}</p>
        <p class="flex items-center gap-2 border-t border-slate-100 pt-4 text-sm font-semibold text-primary">
          Learn more
          <Icon name="arrow_forward" size="text-sm" />
        </p>
      </article>
    ))}
  </div>
</section>

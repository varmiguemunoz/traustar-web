---
interface Props {
  alphabet: string[];
}

const { alphabet } = Astro.props;
---

<section class="mx-auto mb-12 w-full max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="flex flex-wrap gap-2 rounded-xl border border-slate-200 bg-slate-50 p-2">
    <button class="flex h-10 w-12 items-center justify-center rounded-lg bg-primary text-sm font-bold text-white" type="button">All</button>
    {alphabet.map((letter) => (
      <button
        class="flex h-10 w-10 items-center justify-center rounded-lg text-sm font-semibold text-slate-600 transition-colors hover:bg-white"
        type="button"
      >
        {letter}
      </button>
    ))}
  </div>
</section>

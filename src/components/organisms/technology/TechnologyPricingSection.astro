---
import Icon from '@/components/atoms/Icon.astro';
import type { TechnologyFeature } from '@/data/technology';

interface Props {
  features: TechnologyFeature[];
}

const { features } = Astro.props;
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Data-Driven Pricing</h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-600">
        We combine market intelligence and automation to produce transparent, competitive freight pricing.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {features.map((feature) => (
        <article class="rounded-xl border border-slate-200 bg-white p-8 transition-colors hover:border-primary/40">
          <Icon name={feature.icon} className="text-primary" size="text-4xl" />
          <h3 class="mt-4 text-xl font-bold text-slate-900">{feature.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

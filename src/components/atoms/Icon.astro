---
import GlyphIcon from '@/components/icons/GlyphIcon.astro';
import { resolveIcon } from '@/components/icons/iconMap';

interface Props {
  name: string;
  size?: string;
  filled?: boolean;
  className?: string;
  class?: string;
  width?: number | string;
  height?: number | string;
  title?: string;
  strokeWidth?: number | string;
}

const {
  name,
  size = '',
  filled = false,
  className = '',
  class: classAttr = '',
  width,
  height,
  title,
  strokeWidth = 1.8
} = Astro.props as Props;

const glyph = resolveIcon(name);
const classes = ['inline-block shrink-0 align-middle', size, className, classAttr].filter(Boolean).join(' ');
---

<GlyphIcon
  glyph={glyph}
  class={classes}
  width={width}
  height={height}
  title={title}
  strokeWidth={strokeWidth}
  filled={filled}
/>

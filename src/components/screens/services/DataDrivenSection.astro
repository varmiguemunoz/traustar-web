---
/**
 * DataDrivenSection — Full-width bg-primary section with icon-text features.
 * Used on Spot & Contract page.
 */
import Icon from '@/components/atoms/Icon.astro';

interface DataFeature {
	icon: string;
	title: string;
	description: string;
}

interface Props {
	title: string;
	subtitle: string;
	features: DataFeature[];
}

const { title, subtitle, features } = Astro.props;
---

<section class="bg-primary text-white rounded-2xl p-8 md:p-16 my-12 md:my-20 mx-4 sm:mx-6 lg:mx-auto max-w-7xl">
	<div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
		<h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight">{title}</h2>
		<p class="text-lg md:text-xl text-white/80">{subtitle}</p>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
			{features.map((feat) => (
				<div class="flex flex-col items-center gap-3">
					<div class="size-14 rounded-full bg-white/10 flex items-center justify-center">
						<Icon name={feat.icon} size="text-3xl" />
					</div>
					<h4 class="font-bold text-lg">{feat.title}</h4>
					<p class="text-sm text-white/70">{feat.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

---
/**
 * FleetGrid — Equipment/fleet cards with image, title, description, and tags.
 * Used on Flatbed page.
 */

interface FleetCard {
	image: string;
	imageAlt: string;
	title: string;
	description: string;
	tags: string[];
}

interface Props {
	sectionTitle: string;
	sectionSubtitle?: string;
	cards: FleetCard[];
	ctaText?: string;
	ctaHref?: string;
}

const { sectionTitle, sectionSubtitle, cards, ctaText, ctaHref } = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-12 gap-6">
			<div class="max-w-2xl">
				<h2 class="text-3xl font-bold mb-4">{sectionTitle}</h2>
				{sectionSubtitle && (
					<p class="text-slate-600">{sectionSubtitle}</p>
				)}
			</div>
			{ctaText && ctaHref && (
				<a class="text-primary font-bold flex items-center gap-2 group" href={ctaHref}>
					{ctaText}
					<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
				</a>
			)}
		</div>
		<div class="grid md:grid-cols-3 gap-8">
			{cards.map((card) => (
				<div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-200 group hover:shadow-xl transition-all">
					<div
						class="h-48 bg-slate-100 bg-cover bg-center"
						style={`background-image: url('${card.image}');`}
						role="img"
						aria-label={card.imageAlt}
					></div>
					<div class="p-6">
						<h3 class="font-bold text-xl mb-2">{card.title}</h3>
						<p class="text-sm text-slate-500 mb-4">{card.description}</p>
						<div class="flex flex-wrap gap-2">
							{card.tags.map((tag) => (
								<span class="bg-slate-100 text-xs font-bold px-2 py-1 rounded">{tag}</span>
							))}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

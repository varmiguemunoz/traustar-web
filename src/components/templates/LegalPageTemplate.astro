---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Icon from '@/components/atoms/Icon.astro';

interface TocItem {
  id: string;
  icon: string;
  label: string;
}

interface SectionItem {
  id: string;
  title: string;
  body: string[];
}

interface Props {
  seoTitle: string;
  seoDescription: string;
  pageTitle: string;
  updatedAt: string;
  toc: TocItem[];
  sections: SectionItem[];
  contactLabel: string;
  contactEmail: string;
}

const {
  seoTitle,
  seoDescription,
  pageTitle,
  updatedAt,
  toc,
  sections,
  contactLabel,
  contactEmail
} = Astro.props;
---

<SiteLayout title={seoTitle} description={seoDescription}>
  <section class="bg-background-light px-4 pb-20 pt-28 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-12 lg:flex-row">
        <aside class="lg:w-1/4">
          <div class="sticky top-24 space-y-1">
            <div class="mb-6 px-3">
              <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Contents</h2>
            </div>
            {toc.map((item, index) => (
              <a
                href={`#${item.id}`}
                class:list={[
                  'flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                  index === 0 ? 'bg-primary/10 text-primary' : 'text-slate-600 hover:bg-slate-100'
                ]}
              >
                <Icon name={item.icon} size="text-lg" />
                {item.label}
              </a>
            ))}
          </div>
        </aside>

        <article class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm lg:w-3/4">
          <div class="p-8 md:p-12">
            <header class="mb-10 border-b border-slate-100 pb-8">
              <h1 class="mb-4 text-3xl font-black tracking-tight text-slate-900 md:text-4xl">{pageTitle}</h1>
              <p class="flex items-center gap-2 text-slate-500">
                <Icon name="calendar_today" size="text-base" />
                Last updated: {updatedAt}
              </p>
            </header>

            <div class="space-y-10">
              {sections.map((section) => (
                <section class="scroll-mt-24" id={section.id}>
                  <h2 class="mb-4 text-xl font-bold text-slate-900">{section.title}</h2>
                  <div class="space-y-4">
                    {section.body.map((paragraph) => (
                      <p class="leading-relaxed text-slate-600">{paragraph}</p>
                    ))}
                  </div>
                </section>
              ))}
            </div>

            <div class="mt-16 flex flex-col items-start justify-between gap-6 border-t border-slate-100 pt-8 sm:flex-row sm:items-center">
              <div class="flex items-center gap-4">
                <div class="flex size-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <Icon name="mail" />
                </div>
                <div>
                  <h3 class="font-bold text-slate-900">{contactLabel}</h3>
                  <a class="text-sm text-slate-500 hover:text-primary" href={`mailto:${contactEmail}`}>{contactEmail}</a>
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</SiteLayout>

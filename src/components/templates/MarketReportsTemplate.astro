---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Icon from '@/components/atoms/Icon.astro';
import Button from '@/components/atoms/Button.astro';
import MarketDashboard from '@/components/organisms/resources/MarketDashboard.astro';

interface SpotRateCard {
  icon: string;
  label: string;
  trend: string;
  price: string;
  change: string;
  positive: boolean;
  accentClass: string;
}

interface RegionItem {
  name: string;
  status: string;
  percentage: number;
  statusClass: string;
  barClass: string;
}

interface Props {
  seoTitle: string;
  seoDescription: string;
  hero: {
    title: string;
    description: string;
  };
  spotRates: SpotRateCard[];
  regions: RegionItem[];
  summary: string[];
  cta: {
    title: string;
    description: string;
    label: string;
    href: string;
  };
}

const { seoTitle, seoDescription, hero, spotRates, regions, summary, cta } = Astro.props;
---

<SiteLayout title={seoTitle} description={seoDescription}>
  <section class="mx-auto w-full max-w-7xl px-4 pb-8 pt-28 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <header>
        <h1 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">{hero.title}</h1>
        <p class="mt-2 max-w-2xl text-lg text-slate-500">{hero.description}</p>
      </header>
      <div class="flex gap-3">
        <button class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-bold shadow-sm transition-colors hover:bg-slate-50" type="button">
          <Icon name="download" size="text-lg" />
          Download PDF
        </button>
        <Button variant="primary" size="sm" className="flex items-center gap-2 shadow-md">
          <Icon name="share" size="text-lg" />
          Share report
        </Button>
      </div>
    </div>
  </section>

  <MarketDashboard spotRates={spotRates} regions={regions} summary={summary} cta={cta} />
</SiteLayout>

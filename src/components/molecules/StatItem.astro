---
/**
 * StatItem molecule — metric number + label for the metrics bar
 * @param value - The big metric number (e.g. "50k+")
 * @param label - Description label (e.g. "Cargas Entregadas")
 */
interface Props {
	value: string;
	label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center">
	<p class="text-primary text-4xl lg:text-5xl font-black mb-2">{value}</p>
	<p class="text-slate-400 text-sm font-medium uppercase tracking-widest">{label}</p>
</div>

---
/**
 * NavLink molecule — nav anchor with hover color transition
 * @param href - Link destination
 * @param label - Link text
 */
interface Props {
	href?: string;
	label: string;
}

const { href = '#', label } = Astro.props;
---

<a
	href={href}
	class="text-sm font-semibold hover:text-primary transition-colors"
>
	{label}
</a>

---
import Icon from '../atoms/Icon.astro';

interface Props {
  count?: number;
  rating?: number;
}

const { count, rating } = Astro.props;
const fullStars = Math.max(0, Math.min(5, Math.round(rating ?? count ?? 5)));
---

<div class="flex text-primary" aria-label={`Rated ${fullStars} out of 5`}>
  {Array.from({ length: fullStars }).map(() => (
    <Icon name="star" filled={true} />
  ))}
</div>

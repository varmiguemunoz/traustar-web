---
/**
 * TestimonialStars molecule — 5-star rating display
 * @param count - Number of filled stars (default: 5)
 */
import Icon from '../atoms/Icon.astro';

interface Props {
	count?: number;
}

const { count = 5 } = Astro.props;
---

<div class="flex text-primary">
	{Array.from({ length: count }).map(() => (
		<Icon name="star" filled={true} />
	))}
</div>

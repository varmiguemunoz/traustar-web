---
import BaseHead from '../../components/BaseHead.astro';
import Navbar from '../../components/organisms/Navbar.astro';
import SiteFooter from '../../components/organisms/SiteFooter.astro';
import Icon from '../../components/atoms/Icon.astro';
import Button from '../../components/atoms/Button.astro';

const title = 'Solicitar Cotización | Traustar Logistics Inc.';
const description = 'Obtenga precios precisos basados en datos reales y optimice su cadena de suministro con nuestra tecnología logística avanzada.';

const shipmentTypes = [
	{ icon: 'local_shipping', label: 'FTL (Completa)', href: '/quote/ftl' },
	{ icon: 'inventory_2', label: 'LTL (Consolidado)', href: '/quote/ltl' },
	{ icon: 'public', label: 'Cross-Border', href: '/quote/cross-border' },
	{ icon: 'train', label: 'Intermodal', href: '/quote' },
];

const valueProps = [
	{ icon: 'track_changes', title: 'Rastreo GPS 24/7', description: 'Visibilidad total de su carga en tiempo real desde origen hasta destino final.' },
	{ icon: 'verified_user', title: 'Red de Transportistas Verificada', description: 'Solo trabajamos con operadores certificados y rigurosamente auditados.' },
	{ icon: 'rocket_launch', title: 'Tecnología 2026-Ready', description: 'Algoritmos inteligentes para optimizar rutas y reducir costos operativos.' },
];

const specialRequirements = [
	{ label: 'Reefer (Refrigerado)' },
	{ label: 'Flatbed (Plataforma)' },
	{ label: 'Liftgate (Rampa)' },
	{ label: 'Entrega Residencial' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-white text-slate-900 font-display">
		<Navbar />

		<!-- Hero Section -->
		<section class="relative bg-slate-900 py-16 lg:py-24 overflow-hidden">
			<div class="absolute inset-0 opacity-30">
				<div class="absolute inset-0 bg-gradient-to-r from-primary/40 to-transparent z-10"></div>
				<img alt="Centro logístico moderno" class="w-full h-full object-cover" src="/images/quote-hero.jpg" loading="eager" />
			</div>
			<div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h1 class="text-4xl md:text-6xl font-black text-white leading-tight tracking-tight mb-6">
					Solicitar Cotización en Minutos
				</h1>
				<p class="text-lg md:text-xl text-slate-200 max-w-2xl mx-auto font-normal leading-relaxed">
					Obtenga precios precisos basados en datos reales y optimice su cadena de suministro con nuestra tecnología logística avanzada.
				</p>
			</div>
		</section>

		<!-- Main Content -->
		<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-12 pb-24 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Quote Form -->
				<div class="lg:col-span-8 bg-white rounded-xl shadow-xl border border-slate-200 p-6 md:p-10">
					<form class="space-y-10">
						<!-- 1. Shipment Type -->
						<div>
							<div class="flex items-center gap-2 mb-6">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">1</span>
								<h2 class="text-xl font-bold">Tipo de Envío</h2>
							</div>
							<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
								{shipmentTypes.map((type) => (
									<a href={type.href} class="relative flex flex-col items-center justify-center p-4 border-2 border-slate-100 rounded-xl cursor-pointer hover:border-primary/50 transition-all group text-center">
										<Icon name={type.icon} size="text-3xl" className="mb-2 text-slate-400 group-hover:text-primary transition-colors" />
										<span class="text-xs font-bold">{type.label}</span>
									</a>
								))}
							</div>
						</div>

						<!-- 2. Origin & Destination -->
						<div>
							<div class="flex items-center gap-2 mb-6">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">2</span>
								<h2 class="text-xl font-bold">Origen y Destino</h2>
							</div>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<div class="space-y-2">
									<label class="text-sm font-semibold text-slate-600">Origen (CP, Ciudad, Estado)</label>
									<div class="relative">
										<span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icon name="location_on" /></span>
										<input class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary transition-all" placeholder="Ej. 64000 Monterrey, NL" type="text" />
									</div>
								</div>
								<div class="space-y-2">
									<label class="text-sm font-semibold text-slate-600">Destino (CP, Ciudad, Estado)</label>
									<div class="relative">
										<span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icon name="flag" /></span>
										<input class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary transition-all" placeholder="Ej. 77000 Laredo, TX" type="text" />
									</div>
								</div>
							</div>
						</div>

						<!-- 3. Cargo Details -->
						<div>
							<div class="flex items-center gap-2 mb-6">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">3</span>
								<h2 class="text-xl font-bold">Detalles de la Carga</h2>
							</div>
							<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
								<div class="space-y-2">
									<label class="text-sm font-semibold text-slate-600">Tipo de Mercancía</label>
									<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="Ej. Electrónicos" type="text" />
								</div>
								<div class="space-y-2">
									<label class="text-sm font-semibold text-slate-600">Peso Total (kg/lbs)</label>
									<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="15,000 kg" type="text" />
								</div>
								<div class="space-y-2">
									<label class="text-sm font-semibold text-slate-600">Número de Pallets</label>
									<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="24" type="number" />
								</div>
							</div>
							<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
								<h3 class="text-sm font-bold text-slate-800 md:col-span-2">Requerimientos Especiales</h3>
								{specialRequirements.map((req) => (
									<label class="flex items-center gap-3 p-3 border border-slate-100 rounded-lg cursor-pointer hover:bg-slate-50 transition-colors">
										<input class="rounded text-primary focus:ring-primary" type="checkbox" />
										<span class="text-sm">{req.label}</span>
									</label>
								))}
							</div>
						</div>

						<!-- 4. Contact Info -->
						<div class="bg-primary/5 p-6 md:p-8 rounded-xl border border-primary/20">
							<div class="flex items-center gap-2 mb-6">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-white font-bold text-sm">4</span>
								<h2 class="text-xl font-bold">Información de Contacto</h2>
							</div>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="Nombre Completo" type="text" />
								<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="Nombre de la Empresa" type="text" />
								<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="Correo Electrónico Corporativo" type="email" />
								<input class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-primary focus:border-primary" placeholder="Teléfono de Contacto" type="tel" />
							</div>
						</div>

						<div class="pt-4">
							<Button variant="primary" size="lg" className="w-full shadow-lg shadow-primary/20 flex items-center justify-center gap-2 text-lg">
								Obtener Mi Cotización Ahora <Icon name="arrow_forward" />
							</Button>
							<p class="text-center text-xs text-slate-500 mt-4">
								Al enviar este formulario, usted acepta nuestra <a class="underline text-primary" href="/privacidad">Política de Privacidad</a>. Recibirá una respuesta en menos de 15 minutos.
							</p>
						</div>
					</form>
				</div>

				<!-- Sidebar -->
				<div class="lg:col-span-4 space-y-6">
					<!-- Value Props -->
					<div class="bg-white rounded-xl shadow-md border border-slate-200 p-6">
						<h3 class="text-lg font-bold mb-6 text-primary">¿Por qué elegir Traustar?</h3>
						<div class="space-y-6">
							{valueProps.map((prop) => (
								<div class="flex gap-4">
									<div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
										<Icon name={prop.icon} />
									</div>
									<div>
										<h4 class="font-bold text-sm">{prop.title}</h4>
										<p class="text-xs text-slate-500 leading-relaxed mt-1">{prop.description}</p>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- Trust Signals -->
					<div class="bg-slate-900 rounded-xl shadow-md p-6 text-white">
						<h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-4 text-center">Certificaciones y Cumplimiento</h3>
						<div class="grid grid-cols-2 gap-4 items-center opacity-70">
							<div class="flex flex-col items-center gap-1">
								<Icon name="policy" size="text-4xl" />
								<span class="text-[10px] font-bold">FMCSA LICENSED</span>
							</div>
							<div class="flex flex-col items-center gap-1">
								<Icon name="shield_with_heart" size="text-4xl" />
								<span class="text-[10px] font-bold">CTPAT READY</span>
							</div>
						</div>
						<hr class="my-6 border-slate-700" />
						<div class="text-center">
							<p class="text-xs italic text-slate-300 leading-relaxed">
								"Ofrecemos un servicio boutique personalizado. Cada cliente cuenta con un gestor de cuenta dedicado disponible las 24 horas."
							</p>
						</div>
					</div>

					<!-- Map Widget -->
					<div class="rounded-xl overflow-hidden shadow-md border border-slate-200 h-48 relative">
						<img alt="Mapa de Norteamérica" class="w-full h-full object-cover" src="/images/quote-map.jpg" loading="lazy" />
						<div class="absolute inset-0 bg-primary/20 flex items-center justify-center">
							<div class="bg-white/90 p-2 rounded-lg text-[10px] font-bold shadow-lg">
								CONECTANDO USA • MX • CAN
							</div>
						</div>
					</div>
				</div>
			</div>
		</main>

		<SiteFooter />
	</body>
</html>

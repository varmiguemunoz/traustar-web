---
import SiteLayout from '@/layouts/SiteLayout.astro';
import { aboutCertifications, aboutCoverage, aboutPageSeo, aboutValues } from '@/data/about';
import AboutHero from '@/components/organisms/about/AboutHero.astro';
import CompanyStory from '@/components/organisms/about/CompanyStory.astro';
import MissionVisionValues from '@/components/organisms/about/MissionVisionValues.astro';
import CertificationsSection from '@/components/organisms/about/CertificationsSection.astro';
import CoverageSection from '@/components/organisms/about/CoverageSection.astro';
import AboutCta from '@/components/organisms/about/AboutCta.astro';
---

<SiteLayout title={aboutPageSeo.title} description={aboutPageSeo.description}>
  <AboutHero />
  <CompanyStory />
  <MissionVisionValues items={aboutValues} />
  <CertificationsSection items={aboutCertifications} />
  <CoverageSection items={aboutCoverage} />
  <AboutCta />
</SiteLayout>

---
import FaqPageTemplate from '@/components/templates/FaqPageTemplate.astro';
import { faqCategories, faqHero, faqPageSeo, faqSupportCta } from '@/data/faq';
---

<FaqPageTemplate
  seoTitle={faqPageSeo.title}
  seoDescription={faqPageSeo.description}
  heroTitle={faqHero.title}
  heroDescription={faqHero.description}
  searchPlaceholder={faqHero.searchPlaceholder}
  categories={faqCategories}
  supportCta={faqSupportCta}
/>

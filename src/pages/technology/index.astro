---
import BaseHead from '@/components/BaseHead.astro';
import Navbar from '@/components/organisms/Navbar.astro';
import SiteFooter from '@/components/organisms/SiteFooter.astro';
import Icon from '@/components/atoms/Icon.astro';
import Button from '@/components/atoms/Button.astro';

const title = 'Tecnología | Traustar Logistics Inc.';
const description = 'Revolucionando las cadenas de suministro globales con análisis de datos de vanguardia, enrutamiento impulsado por IA y conectividad perfecta.';

const pricingFeatures = [
	{ icon: 'analytics', title: 'Market Analytics', description: 'Aprovechamos datos históricos y en tiempo real del mercado para garantizar precios competitivos que reflejan las tendencias actuales de capacidad.' },
	{ icon: 'payments', title: 'Dynamic Rate Engine', description: 'Algoritmos automatizados que se ajustan a las fluctuaciones de capacidad al instante, proporcionando cotizaciones transparentes basadas en el mercado.' },
	{ icon: 'trending_up', title: 'Cost Optimization', description: 'Identifique oportunidades de ahorro a través de la consolidación inteligente de rutas y cargas impulsada por nuestra lógica de emparejamiento propietaria.' },
];

const networkFeatures = [
	{ icon: 'verified', text: 'Verificación automatizada de seguridad y seguros' },
	{ icon: 'security', text: 'Monitoreo de cumplimiento 24/7 y prevención de fraude' },
	{ icon: 'lan', text: 'Integración EDI/API perfecta con TMS de transportistas' },
];

const networkStats = [
	{ value: '45k+', label: 'Vetted Carriers' },
	{ value: '99.8%', label: 'Compliance Rate' },
	{ value: 'AI', label: 'Risk Analysis' },
	{ value: '1hr', label: 'Avg. Vetting Time' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-white text-slate-900 font-display">
		<Navbar />

		<!-- Hero Section -->
		<section class="relative h-[600px] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 bg-slate-900">
				<div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/80 to-transparent z-10"></div>
				<div class="w-full h-full opacity-40 bg-cover bg-center" style="background-image: url('/images/tech-hero.jpg');"></div>
			</div>
			<div class="relative z-20 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
				<div class="max-w-[800px] flex flex-col gap-6">
					<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 text-primary text-xs font-bold uppercase tracking-wider w-fit">
						<Icon name="bolt" size="text-sm" />
						El Futuro del Freight
					</div>
					<h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-black leading-tight tracking-tight">
						Logística Impulsada por Inteligencia
					</h1>
					<p class="text-slate-300 text-lg md:text-xl max-w-2xl leading-relaxed">
						Revolucionando las cadenas de suministro globales con análisis de datos de vanguardia, enrutamiento impulsado por IA y conectividad perfecta para la empresa moderna.
					</p>
					<div class="flex flex-wrap gap-4 mt-4">
						<Button variant="primary" size="lg" className="hover:scale-105 transition-transform">Solicitar Cotización</Button>
						<Button variant="secondary" size="lg" className="bg-white/10 text-white backdrop-blur-sm border-white/20 hover:bg-white/20">Conocer Más</Button>
					</div>
				</div>
			</div>
		</section>

		<!-- Real-Time Visibility -->
		<section class="py-20 bg-white">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col gap-4 mb-12">
					<h2 class="text-slate-900 text-3xl md:text-4xl font-bold tracking-tight">Visibilidad en Tiempo Real</h2>
					<p class="text-slate-600 text-lg max-w-3xl">Manténgase informado con seguimiento 24/7 y un portal de cliente integral diseñado para total transparencia en la cadena de suministro.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<div class="group flex flex-col gap-6 p-1 bg-slate-100 rounded-xl overflow-hidden hover:shadow-xl transition-all">
						<div class="w-full h-64 bg-cover bg-center rounded-lg" style="background-image: url('/images/tech-gps.jpg');"></div>
						<div class="px-6 pb-6">
							<div class="flex items-center gap-3 mb-3">
								<span class="p-2 bg-primary/10 rounded-lg"><Icon name="location_on" className="text-primary" /></span>
								<h3 class="text-slate-900 text-xl font-bold">Rastreo GPS 24/7</h3>
							</div>
							<p class="text-slate-600 leading-relaxed">Datos de ubicación precisos para cada envío, actualizados en tiempo real en todo el mundo. Monitoree velocidad, cumplimiento de ruta y tiempos de llegada estimados al minuto.</p>
						</div>
					</div>
					<div class="group flex flex-col gap-6 p-1 bg-slate-100 rounded-xl overflow-hidden hover:shadow-xl transition-all">
						<div class="w-full h-64 bg-cover bg-center rounded-lg" style="background-image: url('/images/tech-dashboard.jpg');"></div>
						<div class="px-6 pb-6">
							<div class="flex items-center gap-3 mb-3">
								<span class="p-2 bg-primary/10 rounded-lg"><Icon name="dashboard" className="text-primary" /></span>
								<h3 class="text-slate-900 text-xl font-bold">Portal de Cliente Interactivo</h3>
							</div>
							<p class="text-slate-600 leading-relaxed">Un hub centralizado para gestionar documentos, rastrear historial y comunicarse con despacho. Acceda a facturas, PODs y reportes personalizados desde cualquier dispositivo.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Data-Driven Pricing -->
		<section class="py-20 bg-slate-50">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col items-center text-center gap-4 mb-16">
					<h2 class="text-slate-900 text-3xl md:text-4xl font-bold tracking-tight">Precios Basados en Datos</h2>
					<p class="text-slate-600 text-lg max-w-2xl">Aprovechamos big data para eliminar la volatilidad del mercado y proporcionar las tarifas más competitivas de la industria.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{pricingFeatures.map((feature) => (
						<div class="flex flex-col gap-4 p-8 rounded-xl border border-slate-200 bg-white hover:border-primary transition-colors">
							<Icon name={feature.icon} className="text-primary" size="text-4xl" />
							<h3 class="text-slate-900 text-xl font-bold">{feature.title}</h3>
							<p class="text-slate-600 text-sm leading-relaxed">{feature.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Integrated Carrier Network -->
		<section class="py-20 bg-white overflow-hidden">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col md:flex-row items-center gap-12">
					<div class="flex-1 flex flex-col gap-6">
						<h2 class="text-slate-900 text-3xl md:text-4xl font-bold tracking-tight">Red Integrada de Transportistas</h2>
						<p class="text-slate-600 text-lg leading-relaxed">
							Nuestra tecnología no solo rastrea cargas; gestiona todo el ecosistema. Utilizamos sistemas de verificación automatizados para asegurar que cada transportista en nuestra red cumpla con los más altos estándares de seguridad y confiabilidad.
						</p>
						<ul class="flex flex-col gap-4">
							{networkFeatures.map((item) => (
								<li class="flex items-center gap-3 text-slate-700">
									<Icon name={item.icon} className="text-primary" />
									<span>{item.text}</span>
								</li>
							))}
						</ul>
					</div>
					<div class="flex-1 relative">
						<div class="absolute -inset-4 bg-primary/10 rounded-full blur-3xl"></div>
						<div class="relative grid grid-cols-2 gap-4">
							{networkStats.map((stat, i) => (
								<div class:list={[
									'aspect-square bg-slate-100 rounded-2xl flex flex-col items-center justify-center p-6 text-center gap-2 border border-slate-200',
									i === 1 && 'mt-8',
									i === 2 && '-mt-8',
								]}>
									<span class="text-3xl font-black text-primary">{stat.value}</span>
									<span class="text-xs font-bold text-slate-500 uppercase tracking-widest">{stat.label}</span>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-primary text-white">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center gap-8">
				<h2 class="text-3xl md:text-5xl font-black tracking-tight max-w-2xl">¿Listo para Mejorar la Tecnología de tu Cadena de Suministro?</h2>
				<p class="text-blue-100 text-lg md:text-xl max-w-xl">Únase a cientos de empresas que aprovechan la plataforma inteligente de Traustar para una logística más inteligente.</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/contacto" class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-slate-100 transition-colors">Comenzar Ahora</a>
					<a href="/contacto" class="bg-primary border border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition-colors">Solicitar Demo</a>
				</div>
			</div>
		</section>

		<SiteFooter />
	</body>
</html>

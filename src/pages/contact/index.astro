---
import ContactPageTemplate from '@/components/templates/ContactPageTemplate.astro';
import {
  contactAvailability,
  contactCards,
  contactHero,
  contactMap,
  contactMetaCards,
  contactPageSeo
} from '@/data/contact';
---

<ContactPageTemplate
  seoTitle={contactPageSeo.title}
  seoDescription={contactPageSeo.description}
  hero={contactHero}
  cards={contactCards}
  availability={contactAvailability}
  metaCards={contactMetaCards}
  map={contactMap}
/>

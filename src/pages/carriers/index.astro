---
import SiteLayout from '@/layouts/SiteLayout.astro';
import {
  carrierBenefits,
  carrierCerts,
  carrierRequirements,
  carriersSeo,
  carrierTestimonials
} from '@/data/carriers';
import CarriersHero from '@/components/organisms/carriers/CarriersHero.astro';
import CarrierBenefits from '@/components/organisms/carriers/CarrierBenefits.astro';
import CarrierTechPreview from '@/components/organisms/carriers/CarrierTechPreview.astro';
import OnboardingRequirements from '@/components/organisms/carriers/OnboardingRequirements.astro';
import CarrierTestimonials from '@/components/organisms/carriers/CarrierTestimonials.astro';
import CarrierCertStrip from '@/components/organisms/carriers/CarrierCertStrip.astro';
import CarrierRegistrationSection from '@/components/organisms/carriers/CarrierRegistrationSection.astro';
---

<SiteLayout title={carriersSeo.title} description={carriersSeo.description}>
  <CarriersHero />
  <CarrierBenefits items={carrierBenefits} />
  <CarrierTechPreview />
  <OnboardingRequirements items={carrierRequirements} />
  <CarrierTestimonials items={carrierTestimonials} />
  <CarrierCertStrip items={carrierCerts} />
  <CarrierRegistrationSection />
</SiteLayout>

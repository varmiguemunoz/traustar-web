---
import BaseHead from '@/components/BaseHead.astro';
import Navbar from '@/components/organisms/Navbar.astro';
import SiteFooter from '@/components/organisms/SiteFooter.astro';
import Icon from '@/components/atoms/Icon.astro';

const title = 'Política de Privacidad | Traustar Logistics';
const description = 'Política de privacidad de Traustar Logistics Inc. Conozca cómo recopilamos, utilizamos y protegemos sus datos personales.';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-white text-slate-900 font-display">
		<Navbar />
		<main class="pt-28 pb-20 px-4 sm:px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<!-- Page Title -->
				<div class="mb-8">
					<h1 class="text-3xl sm:text-4xl font-black leading-tight tracking-tight text-slate-900">Política de Privacidad</h1>
					<p class="text-slate-500 text-base mt-2">Última actualización: 24 de Octubre de 2023 - Traustar Logistics Inc.</p>
				</div>

				<!-- Navigation Tabs -->
				<div class="mb-8 overflow-x-auto">
					<div class="flex border-b border-slate-200 min-w-max">
						<a class="flex flex-col items-center justify-center border-b-[3px] border-primary text-primary pb-3 pt-4 px-6" href="#general">
							<p class="text-sm font-bold">General</p>
						</a>
						<a class="flex flex-col items-center justify-center border-b-[3px] border-transparent text-slate-500 hover:text-primary pb-3 pt-4 px-6 transition-colors" href="#datos">
							<p class="text-sm font-bold">Datos</p>
						</a>
						<a class="flex flex-col items-center justify-center border-b-[3px] border-transparent text-slate-500 hover:text-primary pb-3 pt-4 px-6 transition-colors" href="#derechos">
							<p class="text-sm font-bold">Derechos</p>
						</a>
						<a class="flex flex-col items-center justify-center border-b-[3px] border-transparent text-slate-500 hover:text-primary pb-3 pt-4 px-6 transition-colors" href="#seguridad">
							<p class="text-sm font-bold">Seguridad</p>
						</a>
					</div>
				</div>

				<!-- Content Sections -->
				<div class="space-y-12 text-slate-800">
					<!-- Section 1: Introducción -->
					<section class="scroll-mt-24" id="general">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="info" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">1. Introducción</h2>
						</div>
						<div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
							<p class="text-base leading-relaxed">
								En Traustar Logistics Inc. ("nosotros", "nuestro" o "la Compañía"), valoramos profundamente su privacidad y estamos comprometidos a proteger sus datos personales. Esta Política de Privacidad describe cómo recopilamos, utilizamos, almacenamos y protegemos su información cuando utiliza nuestros servicios logísticos, nuestro sitio web y cualquier otra interacción que tenga con nosotros.
							</p>
							<p class="mt-4 text-base leading-relaxed">
								Al utilizar nuestros servicios, usted acepta las prácticas descritas en este documento de conformidad con las leyes internacionales de protección de datos, incluyendo el GDPR (Reglamento General de Protección de Datos) y la CCPA (Ley de Privacidad del Consumidor de California).
							</p>
						</div>
					</section>

					<!-- Section 2: Recopilación de Información -->
					<section class="scroll-mt-24" id="datos">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="analytics" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">2. Información que Recopilamos</h2>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="bg-white p-6 rounded-xl border border-slate-100">
								<h3 class="font-bold text-lg mb-3 text-primary">Datos Personales</h3>
								<ul class="list-disc pl-5 space-y-2 text-sm">
									<li>Nombre y apellidos</li>
									<li>Dirección de correo electrónico profesional</li>
									<li>Número de teléfono de contacto</li>
									<li>Detalles de facturación y dirección fiscal</li>
									<li>Información de envío y destinatario</li>
								</ul>
							</div>
							<div class="bg-white p-6 rounded-xl border border-slate-100">
								<h3 class="font-bold text-lg mb-3 text-primary">Datos de Uso</h3>
								<ul class="list-disc pl-5 space-y-2 text-sm">
									<li>Dirección IP y ubicación geográfica</li>
									<li>Tipo de navegador y sistema operativo</li>
									<li>Historial de navegación en nuestra plataforma</li>
									<li>Logs de transacciones y estados de envío</li>
									<li>Interacciones con correos electrónicos de soporte</li>
								</ul>
							</div>
						</div>
					</section>

					<!-- Section 3: Propósito del Procesamiento -->
					<section class="scroll-mt-24">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="settings_suggest" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">3. Propósito del Procesamiento</h2>
						</div>
						<div class="bg-white p-6 rounded-xl border border-slate-100">
							<p class="mb-4">Utilizamos su información personal para los siguientes fines legítimos:</p>
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
								<div class="flex items-start gap-3">
									<Icon name="check_circle" className="text-primary/60 text-sm mt-1" />
									<p class="text-sm">Gestión y ejecución de contratos logísticos y de transporte.</p>
								</div>
								<div class="flex items-start gap-3">
									<Icon name="check_circle" className="text-primary/60 text-sm mt-1" />
									<p class="text-sm">Comunicación de actualizaciones de estado de carga en tiempo real.</p>
								</div>
								<div class="flex items-start gap-3">
									<Icon name="check_circle" className="text-primary/60 text-sm mt-1" />
									<p class="text-sm">Prevención de fraudes y cumplimiento de normativas aduaneras.</p>
								</div>
								<div class="flex items-start gap-3">
									<Icon name="check_circle" className="text-primary/60 text-sm mt-1" />
									<p class="text-sm">Mejora continua de nuestra plataforma tecnológica.</p>
								</div>
							</div>
						</div>
					</section>

					<!-- Section 4: Intercambio de Datos -->
					<section class="scroll-mt-24">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="share" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">4. Intercambio de Datos</h2>
						</div>
						<div class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-xl">
							<p class="text-sm font-medium">No vendemos su información personal a terceros. Solo compartimos datos con:</p>
							<ul class="mt-4 space-y-2 text-sm list-none">
								<li class="flex items-center gap-2"><Icon name="arrow_forward" size="text-xs" /> Socios logísticos y transportistas necesarios para completar entregas.</li>
								<li class="flex items-center gap-2"><Icon name="arrow_forward" size="text-xs" /> Autoridades gubernamentales y aduaneras cuando sea requerido por ley.</li>
								<li class="flex items-center gap-2"><Icon name="arrow_forward" size="text-xs" /> Proveedores de servicios de TI para el almacenamiento seguro de datos.</li>
							</ul>
						</div>
					</section>

					<!-- Section 5: Seguridad -->
					<section class="scroll-mt-24" id="seguridad">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="shield_lock" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">5. Medidas de Seguridad</h2>
						</div>
						<div class="bg-white p-6 rounded-xl border border-slate-100">
							<p class="text-base leading-relaxed">
								Implementamos protocolos de seguridad estándar en la industria, incluyendo cifrado SSL/TLS de 256 bits para todas las transmisiones de datos. Nuestras bases de datos están protegidas por firewalls avanzados y auditorías de seguridad periódicas para garantizar la integridad y confidencialidad de su información.
							</p>
						</div>
					</section>

					<!-- Section 6: Derechos del Usuario -->
					<section class="scroll-mt-24" id="derechos">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="gavel" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">6. Sus Derechos (GDPR/CCPA)</h2>
						</div>
						<div class="bg-white p-6 rounded-xl border border-slate-100">
							<p class="mb-4">Usted tiene los siguientes derechos respecto a sus datos personales:</p>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
								<div class="p-4 bg-slate-50 rounded-lg">
									<h4 class="font-bold text-sm mb-1">Acceso y Rectificación</h4>
									<p class="text-xs text-slate-500">Solicitar una copia de sus datos y corregir inexactitudes.</p>
								</div>
								<div class="p-4 bg-slate-50 rounded-lg">
									<h4 class="font-bold text-sm mb-1">Eliminación (Derecho al Olvido)</h4>
									<p class="text-xs text-slate-500">Solicitar que borremos sus datos bajo ciertas condiciones.</p>
								</div>
								<div class="p-4 bg-slate-50 rounded-lg">
									<h4 class="font-bold text-sm mb-1">Portabilidad</h4>
									<p class="text-xs text-slate-500">Recibir sus datos en un formato estructurado y legible.</p>
								</div>
								<div class="p-4 bg-slate-50 rounded-lg">
									<h4 class="font-bold text-sm mb-1">Oposición</h4>
									<p class="text-xs text-slate-500">Oponerse al procesamiento para fines de marketing directo.</p>
								</div>
							</div>
						</div>
					</section>

					<!-- Section 7: Contacto -->
					<section class="scroll-mt-24 pb-10">
						<div class="flex items-center gap-3 mb-4">
							<Icon name="alternate_email" className="text-primary" />
							<h2 class="text-slate-900 text-xl font-bold">7. Contacto de Privacidad</h2>
						</div>
						<div class="bg-navy-deep text-white p-8 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-6">
							<div>
								<h3 class="text-xl font-bold mb-2">¿Tiene alguna duda?</h3>
								<p class="text-slate-300 text-sm">Nuestro Oficial de Protección de Datos está disponible para atender sus consultas.</p>
							</div>
							<a class="flex items-center gap-2 bg-primary px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors" href="mailto:privacidad@traustar.com">
								<Icon name="mail" /> privacidad@traustar.com
							</a>
						</div>
					</section>
				</div>
			</div>
		</main>
		<SiteFooter />
	</body>
</html>

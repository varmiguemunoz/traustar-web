---
import SiteLayout from '@/layouts/SiteLayout.astro';
import {
  shippersBenefits,
  shippersCertifications,
  shippersSeo,
  shippersSolutions
} from '@/data/shippers';
import ShippersHero from '@/components/organisms/shippers/ShippersHero.astro';
import ShippersTrustStrip from '@/components/organisms/shippers/ShippersTrustStrip.astro';
import ShippersBenefitsGrid from '@/components/organisms/shippers/ShippersBenefitsGrid.astro';
import ShippersSolutionsGrid from '@/components/organisms/shippers/ShippersSolutionsGrid.astro';
import ShippersBoutiqueSection from '@/components/organisms/shippers/ShippersBoutiqueSection.astro';
import ShippersLeadFormCta from '@/components/organisms/shippers/ShippersLeadFormCta.astro';
---

<SiteLayout title={shippersSeo.title} description={shippersSeo.description}>
  <ShippersHero />
  <ShippersTrustStrip items={shippersCertifications} />
  <ShippersBenefitsGrid items={shippersBenefits} />
  <ShippersSolutionsGrid items={shippersSolutions} />
  <ShippersBoutiqueSection />
  <ShippersLeadFormCta />
</SiteLayout>

---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Icon from '@/components/atoms/Icon.astro';
---

<SiteLayout
  title="404 | Page Not Found"
  description="The page you requested could not be found. Return to Traustar Logistics main pages."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto w-full max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-xl md:p-12">
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.16em] text-primary">Error 404</p>
      <h1 class="mb-4 text-4xl font-black tracking-tight text-slate-900 md:text-5xl">Page not found</h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-600">
        The page you are looking for does not exist or may have moved to a new route.
      </p>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <a href="/" class="inline-flex min-h-11 items-center justify-center rounded-xl bg-primary px-8 py-3 font-bold text-white transition-colors hover:bg-primary-hover">
          Back to home
        </a>
        <a href="/contact" class="inline-flex min-h-11 items-center justify-center rounded-xl border border-slate-300 px-8 py-3 font-bold text-slate-700 transition-colors hover:bg-slate-50">
          Contact support
        </a>
      </div>

      <p class="mt-6 inline-flex items-center gap-2 text-sm text-slate-500">
        <Icon name="support_agent" size="text-base" />
        Need immediate help? Call +1 (872) 351-9977.
      </p>
    </div>
  </section>
</SiteLayout>

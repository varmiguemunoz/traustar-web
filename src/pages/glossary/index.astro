---
import GlossaryPageTemplate from '@/components/templates/GlossaryPageTemplate.astro';
import {
  glossaryAlphabet,
  glossaryCta,
  glossaryHero,
  glossaryPageSeo,
  glossaryTerms
} from '@/data/glossary';
---

<GlossaryPageTemplate
  seoTitle={glossaryPageSeo.title}
  seoDescription={glossaryPageSeo.description}
  hero={glossaryHero}
  alphabet={glossaryAlphabet}
  terms={glossaryTerms}
  cta={glossaryCta}
/>

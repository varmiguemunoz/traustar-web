---
import Navbar from "@/components/organisms/Navbar.astro";

import { createOgImage } from "@utils/createOgImage";
import { ClientRouter } from "astro:transitions";

import config from "@config/config.json";

import "@styles/global.css";
import SiteFooter from "@/components/organisms/SiteFooter.astro";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  blogpost?: boolean;
  keywords?: string;
  schema?: object | object[];
  ogImageTitle?: string;
  ogImageMeta?: string;
  hreflang?: Array<{ lang: string; url: string }>;
}

const {
  title,
  meta_title,
  description,
  noindex,
  keywords,
  schema,
  ogImageTitle,
  ogImageMeta,
  hreflang,
} = Astro.props;

// Dynamic OG image per page
const ogImage = createOgImage({
  title:
    ogImageTitle ||
    meta_title ||
    title ||
    "Traustar Logistics | Precision Freight Solutions",
  meta:
    ogImageMeta ||
    description ||
    "Reliable freight brokerage, visibility, and cross-border logistics across North America.",
});

// Canonical URL
const canonicalURL = `${config.site.base_url}${Astro.url.pathname.replace(/\/$/, "")}`;

const isPayment = Astro.url.pathname.startsWith("/payment");

// Auto noindex for payment pages
const shouldNoindex = noindex || isPayment;
---

<!doctype html>
<html lang={config.site.lang}>
  <head>
    <!-- Charset FIRST for security (OWASP best practice) -->
    <meta charset="utf-8" />

    <!-- Resource hints - Optimized for critical resources -->
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.traustarlogistics.com" />

    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />

    <!-- theme meta -->
    <meta name="theme-name" content="traustar-logistics" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <title>{meta_title ? meta_title : title ? title : config.site.title}</title>
    <meta
      name="title"
      content={meta_title ? meta_title : title ? title : config.site.title}
    />

    <!-- Canonical fix -->
    <link rel="canonical" href={canonicalURL} itemprop="url" />

    <!-- Hreflang for multilingual support -->
    {
      hreflang &&
        hreflang.map((link) => (
          <link rel="alternate" hreflang={link.lang} href={link.url} />
        ))
    }

    {shouldNoindex && <meta name="robots" content="noindex,nofollow" />}

    <meta
      name="description"
      content={description ? description : config.metadata.meta_description}
    />

    <!-- Keywords (optional context signal) -->
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content={meta_title ? meta_title : title ? title : config.site.title}
    />
    <meta
      property="og:description"
      content={description ? description : config.metadata.meta_description}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Traustar Logistics" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={meta_title ? meta_title : title ? title : config.site.title}
    />
    <meta
      name="twitter:description"
      content={description ? description : config.metadata.meta_description}
    />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org JSON-LD -->
    {
      schema &&
        (Array.isArray(schema) ? (
          schema.map((s) => (
            <script type="application/ld+json" set:html={JSON.stringify(s)} />
          ))
        ) : (
          <script
            type="application/ld+json"
            set:html={JSON.stringify(schema)}
          />
        ))
    }

    <ClientRouter />
  </head>

  <body>
    <Navbar />
    <main class="mx-auto w-full">
      <slot />
    </main>

    <!-- <Whatsapp
      url="sms:+573023278057&body=Hi, I'm interested in your Services 🚀"
    /> -->

    <SiteFooter />
  </body>
</html>
